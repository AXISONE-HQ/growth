// Sub-cohort (a) shipped Deal+Engagement base tables; KAN-791 EXTENDS:
//   - Deal: add pipelineId/currentStageId/enteredStageAt/microObjectiveProgress;
//           value → Decimal default 0; drop status/closedAt
//   - Engagement: dealId becomes REQUIRED FK
//   - Stage: outcomeType + followUpCadence (see model above; relations updated)
//   - DealStageHistory: NEW (replaces lead_stage_history)
//   - StageOutcomeType: NEW enum
// Pre-flight #4 verified microObjectiveProgress = 0 prod contacts (2026-05-03);
// Contact.microObjectiveProgress drop is safe (no backfill needed).
// ─────────────────────────────────────────────

/// Phase 1 (KAN-791) — Deal as the lifecycle entity
/// KAN-879 — CRM Core Schema extensions (status / name / closedAt / lost reason /
/// products / ownership / Company relation / extension columns).
model Deal {
  id                     String          @id @default(cuid())
  tenantId               String          @map("tenant_id")
  contactId              String          @map("contact_id")
  correlationId          String?         @unique @map("correlation_id")
  // KAN-791 — pipeline + stage state (moved from Contact)
  pipelineId             String          @map("pipeline_id")
  currentStageId         String          @map("current_stage_id")
  enteredStageAt         DateTime        @default(now()) @map("entered_stage_at")
  // KAN-791 — per-Deal MO progress (moved from Contact.microObjectiveProgress;
  // pre-flight #4 verified 0 prod contacts had non-default values, no backfill)
  microObjectiveProgress Json            @default("{}") @map("micro_objective_progress")
  // KAN-791 — value defaults to 0 (was Decimal?). KAN-790 deferred enrichment.
  value                  Decimal         @default(0) @db.Decimal(12, 2)
  currency               String          @default("USD") @db.VarChar(3)
  metadata               Json            @default("{}")
  // KAN-879 — CRM Core Schema additions
  name                   String          @default("Untitled deal")
  /// Derived from currentStage.outcomeType via migration backfill; future
  /// transitions should keep this in sync (next cohort wires the engine).
  status                 DealStatus      @default(open)
  /// 0-100 (kept loose as Int; no constraint here — UI / API validate).
  probability            Int?
  expectedCloseDate      DateTime?       @map("expected_close_date") @db.Date
  /// Set when status transitions to won/lost. Migration backfills from
  /// DealStageHistory terminal transitions.
  closedAt               DateTime?       @map("closed_at")
  lostReason             DealLostReason? @map("lost_reason")
  lostReasonDetail       String?         @map("lost_reason_detail")
  wonProductSummary      String?         @map("won_product_summary")
  /// Line-item shape determined by next cohort; opaque Json today.
  products               Json            @default("[]")
  ownerId                String?         @map("owner_id")
  assignedAgentId        String?         @map("assigned_agent_id")
  companyId              String?         @map("company_id")
  externalIds            Json            @default("{}") @map("external_ids")
  customFields           Json            @default("{}") @map("custom_fields")
  aiContext              Json            @default("{}") @map("ai_context")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  // KAN-940 — soft-delete column. Nullable; rows with deletedAt IS NOT NULL
  // are excluded from listDeals by default. Mirrors Company's pattern.
  deletedAt              DateTime?       @map("deleted_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipeline      Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  currentStage  Stage              @relation("DealCurrentStage", fields: [currentStageId], references: [id], onDelete: Restrict)
  // KAN-936 — formalize Deal.ownerId → User FK (was dangling string). Nullable;
  // SET NULL on User delete (Prisma default for optional relations).
  owner         User?              @relation("DealOwner", fields: [ownerId], references: [id])
  engagements   Engagement[]
  stageHistory  DealStageHistory[]
  deferredSends DeferredSend[]
  // KAN-879
  company       Company?           @relation(fields: [companyId], references: [id])
  orders        Order[]

  @@index([tenantId, currentStageId])
  @@index([tenantId, pipelineId])
  @@index([tenantId, contactId])
  @@index([tenantId, status])
  @@index([tenantId, companyId, status])
  @@index([tenantId, expectedCloseDate])
  @@map("deals")
}

/// KAN-814 — Deferred outbound queue.
///
/// When Send Policy returns `defer` (e.g., outside tenant send window) the
/// dispatcher persists the would-be send here instead of the previous
/// log+drop behavior. A 5-min cron worker (Cloud Scheduler → growth-api
/// `/internal/cron/deferred-send-evaluator`) re-evaluates Send Policy on
/// pending rows whose `defer_until` has elapsed. On `allow` → dispatch +
/// mark `dispatched`. On still-defer → increment attempts + push
/// `defer_until` forward. After 12 attempts (~24h) → `expired`.
///
/// **Supersession invariant**: a fresh inbound on the same (deal_id,
/// contact_id) marks pending rows `cancelled` with
/// `cancelReason='superseded_by_fresh_inbound'` BEFORE Brain re-evaluates,
/// so a stale defer doesn't double-send after the new inbound's outbound
/// already fires.
model DeferredSend {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  /// KAN-1005 M2-2 — nullable. Lead Inbox writes (KAN-814) always carry a
  /// Deal anchor; engine-path writes (`replayVia='action_decided'`) may not
  /// (autonomous actions can be objective-driven without a current Deal).
  dealId        String?   @map("deal_id")
  contactId     String    @map("contact_id")
  /// Full payload to re-dispatch. Shape depends on `replayVia`:
  ///   - 'action_send'    (KAN-814 Lead Inbox): { brainDecision, composed,
  ///                       contactEmail, shaperTier, ... }
  ///   - 'action_decided' (KAN-1005 M2-2 engine path): the full
  ///                       ActionDecidedEvent re-publish payload, so the
  ///                       cron replays via publishActionDecided and the
  ///                       full chain (compose + guardrail + dispatch)
  ///                       reruns.
  payload       Json
  deferUntil    DateTime  @map("defer_until")
  deferReason   String    @map("defer_reason")
  /// pending | dispatched | expired | cancelled
  status        String    @default("pending")
  attempts      Int       @default(0)
  lastAttemptAt DateTime? @map("last_attempt_at")
  /// KAN-1005 M2-2 — replay discriminator. Cron switches on this:
  ///   - 'action_send'    → publishActionSend with composed payload (Lead Inbox)
  ///   - 'action_decided' → publishActionDecided with ActionDecidedEvent (engine)
  /// Default 'action_send' preserves back-compat for pre-M2-2 rows.
  replayVia     String    @default("action_send") @map("replay_via")
  /// Set when status='cancelled'. Known values:
  ///   - 'superseded_by_fresh_inbound' (KAN-814 supersession path)
  ///   - 'policy_now_denies' (Send Policy returned deny on re-eval)
  cancelReason  String?   @map("cancel_reason")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Cron worker scan: pending rows whose defer_until has elapsed
  @@index([status, deferUntil])
  // Supersession lookup: pending rows for a (tenant, deal, contact) tuple
  @@index([tenantId, dealId, contactId, status])
  // Tenant-bounded recency queries (audit dashboards, expired-row cleanup)
  @@index([tenantId, createdAt])
  @@map("deferred_sends")
}

/// KAN-791 — DealStageHistory replaces lead_stage_history (deal-scoped, not contact-scoped)
model DealStageHistory {
  id             String   @id @default(cuid())
  dealId         String   @map("deal_id")
  fromStageId    String?  @map("from_stage_id")
  toStageId      String   @map("to_stage_id")
  transitionedAt DateTime @default(now()) @map("transitioned_at")
  /// Semantic descriptor — bounded set: 'normalizer' | 'agent' | 'human' | 'system' | 'rule'
  triggeredBy    String   @map("triggered_by")
  /// Typed FK — populated only when transition came from a Decision firing.
  /// Phase 2 KAN-796 (AI Stages Evolution Logic) emits these at scale.
  decisionId     String?  @map("decision_id")
  metadata       Json     @default("{}")

  deal      Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage Stage?    @relation("DealStageFromHistory", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStage   Stage     @relation("DealStageToHistory", fields: [toStageId], references: [id], onDelete: Restrict)
  decision  Decision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  @@index([dealId, transitionedAt])
  @@index([toStageId])
  @@index([decisionId])
  @@map("deal_stage_history")
}

enum StageOutcomeType {
  open
  terminal_won
