// growth — AI Revenue System by AxisOne
// Multi-tenancy data model — tenant_id on every table
// Prisma ORM with PostgreSQL (Cloud SQL)

generator client {
  provider      = "prisma-client-js"
  // KAN-677: native = local dev (macOS arm64). debian-openssl-3.0.x = Cloud Run
  // (node:20-slim). Without the second target, the production container errors:
  // "Prisma Client could not locate the Query Engine for runtime debian-openssl-3.0.x".
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// MULTI-TENANCY ROOT
// ─────────────────────────────────────────────

model Tenant {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  planTier            String   @default("free") @map("plan_tier")
  blueprintId         String?  @map("blueprint_id")
  aiPermissions       Json     @default("{}") @map("ai_permissions")
  confidenceThreshold Int      @default(70) @map("confidence_threshold")
  // KAN-450 — AI Configuration: typed columns for the Settings → AI tab.
  // confidenceThreshold + aiPermissions stay as-is (Decision Engine consumers).
  autoApproveEnabled  Boolean  @default(false) @map("auto_approve_enabled")
  dailyActionLimit    Int      @default(100)   @map("daily_action_limit")
  // KAN-705: posture for the AI lead-assignment fallback when confidence is
  // below threshold AND no tenant rule fires. Default conservative.
  belowThresholdPosture       LeadAssignmentPosture @default(stay_unassigned) @map("below_threshold_posture")
  // Nullable Pipeline ID — only consulted when belowThresholdPosture =
  // default_pipeline. No FK constraint at the Prisma level (avoids the
  // Tenant↔Pipeline circular ref); validated at app level.
  defaultAssignmentPipelineId String?               @map("default_assignment_pipeline_id")
  // KAN-705: confidence threshold (0..1) for AI assignment fallback. Default 0.5.
  aiAssignmentConfidenceThreshold Float            @default(0.5) @map("ai_assignment_confidence_threshold")
  // KAN-738: agentic loop seam (Sprint 3 / S3.1). When false (default),
  // agentic runs in shadow alongside rules-based — only rules-based emits
  // action.decided. When true, agentic emits action.decided and rules-based
  // is skipped. UI toggle ships in Sprint 4.
  agenticModeEnabled  Boolean  @default(false) @map("agentic_mode_enabled")
  strategyPermissions Json     @default("{}")  @map("strategy_permissions")
  guardrailSettings   Json     @default("{}")  @map("guardrail_settings")
  settings            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  blueprint       Blueprint?       @relation(fields: [blueprintId], references: [id])
  users           User[]
  contacts        Contact[]
  brainSnapshots  BrainSnapshot[]
  objectives      Objective[]
  decisions       Decision[]
  actions         Action[]
  outcomes        Outcome[]
  auditLogs       AuditLog[]
  strategyWeights StrategyWeight[]
  pipelines       Pipeline[]
  microObjectives MicroObjective[]
  guardrails      Guardrail[]
  assignmentRules AssignmentRule[]
  customers       Customer[]
  conversations   Conversation[]
  escalations     Escalation[]
  knowledgeBase    KnowledgeBase[]
  knowledgeSources KnowledgeSource[]
  aiAgentConfigs   AiAgentConfig[]
  contactStates    ContactState[]
  agenticShadowDecisions AgenticShadowDecision[]

  //   tenantSettings  TenantSettings[]  // commented out for smoke build (model missing on main)
  channelConnections ChannelConnection[]
  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("member")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  resolvedEscalations Escalation[] @relation("ResolvedByUser")

  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────
// BLUEPRINTS (global, growth-owned)
// ─────────────────────────────────────────────

model Blueprint {
  id                String   @id @default(uuid())
  vertical          String
  customerModel     Json     @map("customer_model")
  journeys          Json
  strategyTemplates Json     @map("strategy_templates")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenants    Tenant[]
  objectives Objective[]

  @@map("blueprints")
}

// ─────────────────────────────────────────────
// BRAIN SERVICE (UNDERSTAND phase)
// ─────────────────────────────────────────────

model BrainSnapshot {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  companyTruth    Json     @map("company_truth")
  behavioralModel Json     @map("behavioral_model")
  outcomeModel    Json     @map("outcome_model")
  version         Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, version])
  @@map("brain_snapshots")
}

// ─────────────────────────────────────────────
// CONTACTS & STATE
// ─────────────────────────────────────────────

model Contact {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  email            String?
  phone            String?
  firstName        String?   @map("first_name")
  lastName         String?   @map("last_name")
  externalIds      Json      @default("{}") @map("external_ids")
  dataQualityScore Float     @default(0) @map("data_quality_score")
  segment          String?
  lifecycleStage   String    @default("new") @map("lifecycle_stage")
  source           String?
  // KAN-700: pipeline-aware lead state. Lead == Contact (product vocab vs
  // schema vocab — see KAN-700 closure comment). Both pipeline + stage are
  // nullable for V1 (existing contacts pre-assignment). microObjectiveProgress
  // tracks per-MO completion: { microObjectiveId: { completed, completedAt, evidence } }.
  currentPipelineId      String?   @map("current_pipeline_id")
  currentStageId         String?   @map("current_stage_id")
  microObjectiveProgress Json      @default("{}") @map("micro_objective_progress")
  enteredStageAt         DateTime? @map("entered_stage_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  contactStates     ContactState[]
  decisions         Decision[]
  outcomes          Outcome[]
  customer          Customer?
  conversations     Conversation[]
  escalations       Escalation[]
  actions           Action[]
  currentPipeline   Pipeline?          @relation("ContactCurrentPipeline", fields: [currentPipelineId], references: [id], onDelete: SetNull)
  currentStage      Stage?             @relation("ContactCurrentStage", fields: [currentStageId], references: [id], onDelete: SetNull)
  stageHistory      LeadStageHistory[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, lifecycleStage])
  @@index([tenantId, segment])
  @@index([tenantId, dataQualityScore])
  @@index([tenantId, source])
  @@index([tenantId, currentPipelineId])
  @@index([tenantId, currentStageId])
  @@map("contacts")
}

model ContactState {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  contactId       String   @map("contact_id")
  objectiveId     String   @map("objective_id")
  subObjectives   Json     @default("[]") @map("sub_objectives")
  strategyCurrent String?  @map("strategy_current")
  confidenceScore Float    @default(0) @map("confidence_score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  contact   Contact   @relation(fields: [contactId], references: [id])
  objective Objective @relation(fields: [objectiveId], references: [id])

  @@unique([contactId, objectiveId])
  @@index([tenantId])
  @@index([contactId])
  @@map("contact_states")
}

// ─────────────────────────────────────────────
// DECISION ENGINE (DECIDE phase)
// ─────────────────────────────────────────────

model Objective {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  name             String
  type             String
  successCondition Json     @map("success_condition")
  subObjectives    Json     @default("[]") @map("sub_objectives")
  blueprintId      String?  @map("blueprint_id")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  blueprint     Blueprint?     @relation(fields: [blueprintId], references: [id])
  contactStates ContactState[]
  outcomes      Outcome[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@map("objectives")
}

model Decision {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  contactId        String   @map("contact_id")
  strategySelected String   @map("strategy_selected")
  actionType       String   @map("action_type")
  confidence       Float
  reasoning        String?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  contact      Contact            @relation(fields: [contactId], references: [id])
  actions      Action[]
  stageHistory LeadStageHistory[]

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, createdAt])
  @@map("decisions")
}

// ─────────────────────────────────────────────
// AGENT DISPATCHER (EXECUTE phase)
// ─────────────────────────────────────────────

// KAN-738 — Sprint 3 / S3.1 agentic loop seam.
// One row per shadow-mode comparison run. Live mode (Tenant.agentic_mode_enabled
// = true) does NOT write to this table — only the agentic Decision row is
// persisted via the standard Decision model. Shadow mode is the default.
model AgenticShadowDecision {
  id                      String    @id @default(uuid())
  tenantId                String    @map("tenant_id")
  contactId               String    @map("contact_id")
  // FK to Decision row from the rules-based path (always set in shadow mode
  // because rules-based always runs first and emits action.decided).
  decisionId              String?   @map("decision_id")
  agenticDecisionPayload  Json      @map("agentic_decision_payload")
  rulesDecisionPayload    Json      @map("rules_decision_payload")
  // Bounded set — see DivergenceFlag in @growth/shared/decision-payload.ts.
  divergenceFlags         String[]  @map("divergence_flags")
  // Set when divergence_flags includes 'agentic_error'. Indexable for
  // "all failed agentic runs in window X" queries (KAN-745 follow-up will
  // build observability on top of this).
  agenticError            String?   @map("agentic_error")
  createdAt               DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, contactId])
  @@index([tenantId, agenticError])
  @@map("agentic_shadow_decisions")
}

model Action {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  decisionId   String    @map("decision_id")
  contactId    String    @map("contact_id")
  agentType    String    @map("agent_type")
  channel      String?
  payload      Json      @default("{}")
  status       String    @default("pending")
  sentAt       DateTime? @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  failedAt     DateTime? @map("failed_at")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  decision Decision @relation(fields: [decisionId], references: [id])
  contact  Contact  @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([decisionId])
  @@map("actions")
}

// ─────────────────────────────────────────────
// LEARNING SERVICE (LEARN phase)
// ─────────────────────────────────────────────

model Outcome {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  contactId      String   @map("contact_id")
  objectiveId    String   @map("objective_id")
  result         String
  reasonCategory String?  @map("reason_category")
  metadata       Json     @default("{}")
  recordedAt     DateTime @default(now()) @map("recorded_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  contact   Contact   @relation(fields: [contactId], references: [id])
  objective Objective @relation(fields: [objectiveId], references: [id])

  @@index([tenantId])
  @@index([tenantId, objectiveId])
  @@index([tenantId, result])
  @@map("outcomes")
}

// ─────────────────────────────────────────────
// ACTION OUTCOMES — KAN-657
// One row per action.executed event. Distinct from Outcome (above), which
// tracks objective resolution per KAN-9. Sibling table; no overlap in
// runtime usage today.
// ─────────────────────────────────────────────
model ActionOutcome {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  decisionId String   @map("decision_id")
  contactId  String   @map("contact_id")
  action     String   // 'email_send' | 'sms_send' | 'meta_send'
  status     String   // 'sent' | 'delivered' | 'failed' | 'suppressed'
  occurredAt DateTime @map("occurred_at")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, decisionId])
  @@index([tenantId, contactId, occurredAt])
  @@index([tenantId, action, status, occurredAt])
  @@map("action_outcomes")
}

model StrategyWeight {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  strategyType String   @map("strategy_type")
  segment      String?
  winRate      Float    @default(0) @map("win_rate")
  sampleSize   Int      @default(0) @map("sample_size")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, strategyType, segment])
  @@index([tenantId])
  @@map("strategy_weights")
}

// ─────────────────────────────────────────────
// AUDIT LOG (immutable)
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  actor      String
  actionType String   @map("action_type")
  payload    Json     @default("{}")
  reasoning  String?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, actionType])
  @@index([tenantId, createdAt])
  @@map("audit_log")
}

// ─────────────────────────────────────────────
// KAN-700: Pipelines, Stages, MicroObjectives, Targets, Guardrails,
// KnowledgeFilters, LeadStageHistory
//
// Replaces the legacy Pipeline + PipelineCard pair (dropped in this same
// migration; both 0 rows in prod, dead-code consumer pipelinesRouter
// removed in same PR). New design: Stage as a first-class table (was a
// JSON blob inside the legacy Pipeline), and per-Lead pipeline state lives
// on Contact.currentPipelineId/currentStageId (was the PipelineCard table).
// ─────────────────────────────────────────────

enum ObjectiveType {
  warm_up_lead
  book_appointment
  buy_online
  send_quote

  @@map("objective_type")
}

enum TargetMetric {
  appointments_booked
  orders_placed
  quotes_sent
  replies_received
  leads_qualified
  revenue_dollars

  @@map("target_metric")
}

enum TargetPeriod {
  weekly
  monthly
  quarterly

  @@map("target_period")
}

enum ValidatorType {
  tone
  accuracy
  hallucination
  compliance
  injection

  @@map("validator_type")
}

enum GuardrailSeverity {
  block
  regenerate
  warn
  pass

  @@map("guardrail_severity")
}

enum KnowledgeCategory {
  company_info
  products
  warranty
  shipping
  financing
  faqs

  @@map("knowledge_category")
}

model Pipeline {
  id                   String        @id @default(uuid())
  tenantId             String        @map("tenant_id")
  name                 String
  description          String?
  isActive             Boolean       @default(true) @map("is_active")
  order                Int           @default(0)
  objectiveType        ObjectiveType @map("objective_type")
  objectiveDescription String?       @map("objective_description")
  // KAN-704: pipeline-tier auto-approve defaults. Resolution order is
  // Stage.autoApproveMatrix → this column → Tenant.autoApproveEnabled
  // (kill-switch) → platform default (auto-approve-defaults.ts). NULL means
  // "skip this tier" (same posture as Stage.autoApproveMatrix when empty).
  defaultAutoApproveMatrix Json?      @map("default_auto_approve_matrix")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages            Stage[]
  microObjectives   PipelineMicroObjective[]
  targets           Target[]
  guardrails        Guardrail[]
  knowledgeFilters  KnowledgeFilter[]
  assignmentRules   AssignmentRule[]
  contacts          Contact[]                @relation("ContactCurrentPipeline")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, objectiveType])
  @@map("pipelines")
}

model Stage {
  id                String   @id @default(uuid())
  pipelineId        String   @map("pipeline_id")
  name              String
  order             Int      @default(0)
  isInitial         Boolean  @default(false) @map("is_initial")
  isTerminal        Boolean  @default(false) @map("is_terminal")
  entryActions      Json     @default("[]") @map("entry_actions")
  transitionRules   Json     @default("[]") @map("transition_rules")
  autoApproveMatrix Json     @default("{}") @map("auto_approve_matrix")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  pipeline           Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  contacts           Contact[]          @relation("ContactCurrentStage")
  fromStageHistory   LeadStageHistory[] @relation("StageFromHistory")
  toStageHistory     LeadStageHistory[] @relation("StageToHistory")

  @@index([pipelineId])
  @@index([pipelineId, order])
  @@map("stages")
}

model MicroObjective {
  id                 String   @id @default(uuid())
  // Nullable for platform defaults (KAN-701 seeds 5 platform-default MOs).
  tenantId           String?  @map("tenant_id")
  name               String
  description        String?
  completionCriteria Json     @default("{}") @map("completion_criteria")
  isDefault          Boolean  @default(false) @map("is_default")
  order              Int      @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant   Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipelines PipelineMicroObjective[]

  @@index([tenantId])
  @@index([isDefault])
  @@map("micro_objectives")
}

model PipelineMicroObjective {
  pipelineId       String  @map("pipeline_id")
  microObjectiveId String  @map("micro_objective_id")
  isActive         Boolean @default(true) @map("is_active")

  pipeline       Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  microObjective MicroObjective @relation(fields: [microObjectiveId], references: [id], onDelete: Cascade)

  @@id([pipelineId, microObjectiveId])
  @@index([microObjectiveId])
  @@map("pipeline_micro_objectives")
}

model Target {
  id              String       @id @default(uuid())
  pipelineId      String       @map("pipeline_id")
  metric          TargetMetric
  value           Decimal      @db.Decimal(14, 2)
  period          TargetPeriod
  // Computed by reporting jobs; nullable until first computation.
  currentProgress Decimal?     @map("current_progress") @db.Decimal(14, 2)
  projection      Decimal?     @db.Decimal(14, 2)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, metric, period])
  @@index([pipelineId])
  @@map("targets")
}

model Guardrail {
  id               String             @id @default(uuid())
  tenantId         String             @map("tenant_id")
  // Null = tenant-wide guardrail; non-null = pipeline-scoped override.
  pipelineId       String?            @map("pipeline_id")
  validatorType    ValidatorType      @map("validator_type")
  severityOverride GuardrailSeverity? @map("severity_override")
  isActive         Boolean            @default(true) @map("is_active")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline Pipeline? @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([tenantId, pipelineId, validatorType])
  @@index([tenantId])
  @@index([tenantId, pipelineId])
  @@map("guardrails")
}

model KnowledgeFilter {
  id                String            @id @default(uuid())
  pipelineId        String            @map("pipeline_id")
  knowledgeCategory KnowledgeCategory @map("knowledge_category")
  includeRule       Json              @default("{}") @map("include_rule")
  excludeRule       Json              @default("{}") @map("exclude_rule")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, knowledgeCategory])
  @@index([pipelineId])
  @@map("knowledge_filters")
}

// KAN-705: tenant-defined deterministic rules that route a new lead to a
// specific pipeline. Evaluated tenant-wide on lead creation in priority order
// (lower = higher precedence); first match wins. JSONB conditions keep V1
// flexible while a future ticket can normalize the predicate language.
//
// Hot path query: `findMany({ where: { tenantId, isActive: true }, orderBy:
// { priority: 'asc' } })` — covered by the (tenantId, isActive, priority)
// composite index.
model AssignmentRule {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  pipelineId String   @map("pipeline_id")
  /// Lower number = higher precedence.
  priority   Int      @default(0)
  /// JSONB predicate matched against Lead fields: source, segment, lifecycleStage, dataQualityScore, email, externalIds.
  conditions Json     @default("{}")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, priority])
  @@index([pipelineId])
  @@map("assignment_rules")
}

enum LeadAssignmentPosture {
  stay_unassigned
  default_pipeline
  escalate_to_human

  @@map("lead_assignment_posture")
}

model LeadStageHistory {
  id            String   @id @default(uuid())
  // leadId == contactId per KAN-700 closure note (Lead == Contact in this schema).
  leadId        String   @map("lead_id")
  fromStageId   String?  @map("from_stage_id")
  toStageId     String   @map("to_stage_id")
  reason        String?
  decisionId    String?  @map("decision_id")
  transitionedAt DateTime @default(now()) @map("transitioned_at")

  contact   Contact   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStage Stage?    @relation("StageFromHistory", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStage   Stage     @relation("StageToHistory", fields: [toStageId], references: [id], onDelete: Restrict)
  decision  Decision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([leadId, transitionedAt])
  @@index([toStageId])
  @@map("lead_stage_history")
}

// ─────────────────────────────────────────────
// EXTENDED: Customers, Conversations, Escalations
// ─────────────────────────────────────────────

model Customer {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  contactId   String   @unique @map("contact_id")
  plan        String?
  mrr         Float    @default(0)
  ltv         Float    @default(0)
  healthScore Float    @default(50) @map("health_score")
  status      String   @default("active")
  since       DateTime @default(now())
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, healthScore])
  @@map("customers")
}

