// growth — AI Revenue System by AxisOne
// Multi-tenancy data model — tenant_id on every table
// Prisma ORM with PostgreSQL (Cloud SQL)

generator client {
  provider      = "prisma-client-js"
  // KAN-677: native = local dev (macOS arm64). debian-openssl-3.0.x = Cloud Run
  // (node:20-slim). Without the second target, the production container errors:
  // "Prisma Client could not locate the Query Engine for runtime debian-openssl-3.0.x".
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// MULTI-TENANCY ROOT
// ─────────────────────────────────────────────

model Tenant {
  id                              String                @id @default(uuid())
  name                            String
  slug                            String                @unique
  planTier                        String                @default("free") @map("plan_tier")
  blueprintId                     String?               @map("blueprint_id")
  aiPermissions                   Json                  @default("{}") @map("ai_permissions")
  confidenceThreshold             Int                   @default(70) @map("confidence_threshold")
  // KAN-450 — AI Configuration: typed columns for the Settings → AI tab.
  // confidenceThreshold + aiPermissions stay as-is (Decision Engine consumers).
  autoApproveEnabled              Boolean               @default(false) @map("auto_approve_enabled")
  // KAN-1042 PR A1 (Phase A foundation) — engine-driven sub-objective
  // transition gate. Mirrors M2-6b autoApproveEnabled pattern: default
  // false → engine emissions of `transition_sub_objective` escalate to
  // Recommendations queue (via KAN-1037 PR1 originalAction); true →
  // dispatcher-arm auto-executes via transitionSubObjectiveState with
  // source='engine'. DISPATCHER-LEVEL gating (consumer reads this flag),
  // NOT a HIGH_STAKES_ACTION_TYPES clamp — per Phase 1 Q6 finding the
  // threshold-gate clamp is binary (tenant cannot opt-in once an action
  // is in the high-stakes set; M2-3 safety invariant always wins).
  autoTransitionSubObjectives     Boolean               @default(false) @map("auto_transition_sub_objectives")
  // KAN-1063 (Cluster II PR I, Phase 1 design trace Lock 5) — engine-driven
  // EnginePhase advancement gate. Sibling to autoTransitionSubObjectives
  // above (KAN-1042 PR A1) + autoApproveEnabled (M2-6b) + sendRedirectEnabled
  // (M2-6a). Default false → engine emissions of `advance_engine_phase`
  // escalate to Recommendations queue via KAN-1037 PR1 originalAction;
  // true → Cluster II PR V's wirePhase2Consumers arm auto-executes via
  // `handleEngineAdvancePhase`. DISPATCHER-LEVEL gating (consumer reads
  // this flag), NOT a HIGH_STAKES_ACTION_TYPES clamp — same architectural
  // distinction as KAN-1042 PR A1.
  autoAdvanceEnginePhase          Boolean               @default(false) @map("auto_advance_engine_phase")
  // KAN-1063 (Cluster II PR I, Phase 1 design trace Lock 3 + Q4) — per-tenant
  // override of Blueprint.enginePhases. Direct on Tenant per engine-config
  // family discipline (sibling to engine-config flags above), NOT on
  // accountProfile sub-model (which is the content-override family,
  // e.g., legalDefaults). When null, engine falls back to
  // `blueprint?.enginePhases` then DEFAULT_ENGINE_PHASES_GENERIC_B2B.
  // Resolution lives in `blueprint-engine-phases-resolver.ts` (Cluster II PR II).
  enginePhasesOverride            Json?                 @map("engine_phases_override")
  dailyActionLimit                Int                   @default(100) @map("daily_action_limit")
  // KAN-1009 SAE PR4 — per-tenant daily LLM cost cap (USD). NULL = use
  // the env-default (DECISION_RUN_DAILY_COST_CAP_USD_DEFAULT, conservative
  // $10/day at ship time). The decision-run-push subscriber reads this
  // before runDecisionForContact; if today's accumulated tenant spend
  // exceeds the resolved cap → skip + structured-log + ack. Counter is
  // Redis-backed (KAN-742 redis-client; daily reset via TTL on UTC date
  // boundary). Per-tenant configurability shipped now so M2 multi-tenant
  // can set per-tenant overrides without a migration; UI surface
  // (settings.ai.update extension) deferred to KAN-1010 follow-up.
  dailyLlmCostCapUsd              Decimal?              @map("daily_llm_cost_cap_usd") @db.Decimal(10, 2)
  // KAN-705: posture for the AI lead-assignment fallback when confidence is
  // below threshold AND no tenant rule fires. Default conservative.
  belowThresholdPosture           LeadAssignmentPosture @default(stay_unassigned) @map("below_threshold_posture")
  // Nullable Pipeline ID — only consulted when belowThresholdPosture =
  // default_pipeline. No FK constraint at the Prisma level (avoids the
  // Tenant↔Pipeline circular ref); validated at app level.
  defaultAssignmentPipelineId     String?               @map("default_assignment_pipeline_id")
  // KAN-705: confidence threshold (0..1) for AI assignment fallback. Default 0.5.
  aiAssignmentConfidenceThreshold Float                 @default(0.5) @map("ai_assignment_confidence_threshold")
  // KAN-738: agentic loop seam (Sprint 3 / S3.1). When false (default),
  // agentic runs in shadow alongside rules-based — only rules-based emits
  // action.decided. When true, agentic emits action.decided and rules-based
  // is skipped. UI toggle ships in Sprint 4.
  agenticModeEnabled              Boolean               @default(false) @map("agentic_mode_enabled")
  // KAN-741: Lead Inbox slug — first 8 chars of tenant UUID by default,
  // regenerable via admin tRPC mutation. Forms the inbox address as
  // <slug>@leads.<LEAD_INBOX_DOMAIN>. Nullable for gradual rollout (legacy
  // tenants stay null until first regenerateSlug call). Unique to prevent
  // collisions across tenants.
  inboxSlug                       String?               @unique @map("inbox_slug")
  // KAN-741: per-tenant DKIM strict-mode override. Default true (strict —
  // reject DKIM=fail AND DKIM=none). Tenant can flip to false via UI for
  // accommodating contacts on legacy mail servers without DKIM signing.
  inboxDkimStrict                 Boolean               @default(true) @map("inbox_dkim_strict")
  strategyPermissions             Json                  @default("{}") @map("strategy_permissions")
  guardrailSettings               Json                  @default("{}") @map("guardrail_settings")
  settings                        Json                  @default("{}")
  // KAN-1005 M2-6a — per-tenant send-redirect gate. The delivery-time
  // switch (paired with M2-6b's decision-time autonomy flip — two
  // independent switches). DEFAULT true so every existing + new tenant
  // continues redirecting to the founder test inbox. Real-send go-live
  // is a separate deliberate per-tenant flip to false, KAN-808 (CAN-SPAM/
  // CASL) compliance HARD prerequisite. This PR ships the mechanism
  // only; no tenant flips in this PR.
  //
  // Read site: apps/connectors/src/adapters/_shared/send-redirect.ts
  // (applyRedirect, called as first line of every adapter send()).
  // Precedence: env SEND_REDIRECT_ENABLED=true (global force-ON master)
  // > per-tenant column > fail-safe redirect-ON on any DB error.
  sendRedirectEnabled             Boolean               @default(true) @map("send_redirect_enabled")
  createdAt                       DateTime              @default(now()) @map("created_at")
  updatedAt                       DateTime              @updatedAt @map("updated_at")

  // Relations
  blueprint               Blueprint?                 @relation(fields: [blueprintId], references: [id])
  users                   User[]
  contacts                Contact[]
  brainSnapshots          BrainSnapshot[]
  objectives              Objective[]
  decisions               Decision[]
  actions                 Action[]
  outcomes                Outcome[]
  auditLogs               AuditLog[]
  strategyWeights         StrategyWeight[]
  pipelines               Pipeline[]
  microObjectives         MicroObjective[]
  guardrails              Guardrail[]
  assignmentRules         AssignmentRule[]
  customers               Customer[]
  conversations           Conversation[]
  escalations             Escalation[]
  knowledgeBase           KnowledgeBase[]
  knowledgeSources        KnowledgeSource[]
  faqEntries              FaqEntry[]
  services                Service[]
  knowledgeGapSummaries   KnowledgeGapSummary[]
  aiAgentConfigs          AiAgentConfig[]
  contactObjectiveStack   ContactObjectiveStack[]
  // KAN-962 (slice 2a) — tenant-level objective declarations
  objectiveSelections     TenantObjectiveSelection[]
  // KAN-962 (slice 2a) — customer-lifecycle append-only audit
  customerLifecycleEvents CustomerLifecycleEvent[]
  agenticShadowDecisions  AgenticShadowDecision[]
  leadInboxEvents         LeadInboxEvent[]
  apiKeys                 TenantApiKey[]
  llmCostRollups          LlmCostRollup[]
  deals                   Deal[]
  engagements             Engagement[]
  deferredSends           DeferredSend[]
  // KAN-852 — Account Page Cohort 1. 1:1 by AccountProfile.tenantId @unique.
  accountProfile          AccountProfile?
  // KAN-879 — CRM Core Schema
  companies               Company[]
  orders                  Order[]
  // KAN-896 — Ingestion Cohort 2.1a (upload backend)
  imports                 ImportJob[]
  // KAN-903 — Ingestion Cohort 2.5 (staging tables). Tenant-scoped so
  // staging-status dashboards + cross-table aggregate queries can join
  // by tenant without going through ImportJob.
  stagingContacts         ImportStagingContact[]
  stagingCompanies        ImportStagingCompany[]
  stagingDeals            ImportStagingDeal[]
  stagingOrders           ImportStagingOrder[]
  // KAN-1001 Campaign Slice 0 — Campaign Layer back-relations.
  campaigns               Campaign[]
  campaignMemberships     CampaignMembership[]

  //   tenantSettings  TenantSettings[]  // commented out for smoke build (model missing on main)
  channelConnections ChannelConnection[]
  // M3-1 Sub-Objective Framework MVP — tenant-scoped discovery state.
  // RESTRICT delete: tenant deletion should never silently drop gap-state.
  subObjectiveGapStates ContactSubObjectiveGapState[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("member")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  resolvedEscalations Escalation[] @relation("ResolvedByUser")
  // KAN-896 — Ingestion Cohort 2.1a (upload backend). Single relation, no name needed.
  imports             ImportJob[]
  // KAN-936 — back-relations for Deal.owner + Company.owner FKs. Optional
  // on the entity side (`ownerId String?`) — nullable; Prisma default for
  // optional relations on user deletion is SET NULL.
  ownedDeals          Deal[]       @relation("DealOwner")
  ownedCompanies      Company[]    @relation("CompanyOwner")

  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────
// BLUEPRINTS (global, growth-owned)
// ─────────────────────────────────────────────

model Blueprint {
  id                String   @id @default(uuid())
  vertical          String
  customerModel     Json     @map("customer_model")
  journeys          Json
  strategyTemplates Json     @map("strategy_templates")
  // KAN-852 — Account Page Cohort 1. Per-vertical legal defaults the
  // /settings/account/legal tab pre-fills when the tenant hasn't
  // overridden them. Shape: keyed by ISO 639-1 language code —
  // { en: { optOutLanguage, emailFooterDisclosure },
  //   fr?: { optOutLanguage, emailFooterDisclosure } } —
  // because CASL applies in Quebec (spec §2 decision 4 locks `en` + `fr`
  // at MVP). The router resolves at read time via
  // resolveLegalDefaults() in blueprint-loader.ts:
  //   tenant override → blueprint.legalDefaults[defaultLanguage] → .en.
  // Backfilled for existing rows with both languages in the same
  // migration. Future verticals populate their own keyed bundles.
  legalDefaults     Json?    @map("legal_defaults")
  // KAN-1063 (Cluster II PR I, Phase 1 design trace Lock 3) — per-vertical
  // 4-phase EnginePhase definitions. Shape (Json):
  // `{ phases: [{ key: 'qualify'|'problem'|'proof'|'closing', label, subObjectives: [...], priority }] }`.
  // Sibling slot positioning to `legalDefaults` above (KAN-852) — both
  // nullable Json with per-tenant override semantics. Per-tenant override
  // lives at `tenants.enginePhasesOverride` (direct on Tenant, engine-config
  // family; see Cluster II Phase 1 Q4 lock for the sub-model placement
  // rationale). Resolution lives in `blueprint-engine-phases-resolver.ts`
  // (Cluster II PR II). When null on Blueprint AND null on Tenant override,
  // engine falls back to DEFAULT_ENGINE_PHASES_GENERIC_B2B.
  enginePhases      Json?    @map("engine_phases")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenants    Tenant[]
  objectives Objective[]

  @@map("blueprints")
}

// ─────────────────────────────────────────────
// BRAIN SERVICE (UNDERSTAND phase)
// ─────────────────────────────────────────────

model BrainSnapshot {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  companyTruth    Json     @map("company_truth")
  behavioralModel Json     @map("behavioral_model")
  outcomeModel    Json     @map("outcome_model")
  version         Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, version])
  @@map("brain_snapshots")
}

// ─────────────────────────────────────────────
// CONTACTS & STATE
// ─────────────────────────────────────────────

model Contact {
  id                String         @id @default(uuid())
  tenantId          String         @map("tenant_id")
  email             String?
  phone             String?
  firstName         String?        @map("first_name")
  lastName          String?        @map("last_name")
  externalIds       Json           @default("{}") @map("external_ids")
  dataQualityScore  Float          @default(0) @map("data_quality_score")
  segment           String?
  // KAN-879 — String → enum coercion via migration CASE WHEN
  // (legacy 'new' rows → 'lead').
  lifecycleStage    LifecycleStage @default(lead) @map("lifecycle_stage")
  // KAN-879 — String? → enum? coercion via migration CASE WHEN
  // (legacy 'inbox_email' → 'email_inbox', unknowns → 'other').
  source            ContactSource?
  // KAN-879 — CRM Core Schema additions
  companyId         String?        @map("company_id")
  companyName       String?        @map("company_name")
  addressLine1      String?        @map("address_line_1")
  addressLine2      String?        @map("address_line_2")
  city              String?
  region            String?
  postalCode        String?        @map("postal_code")
  /// ISO 3166-1 alpha-2.
  country           String?
  // KAN-700 + KAN-791: pipeline-aware lead state.
  // currentPipelineId + currentStageId DEPRECATED in Phase 1 (read-shim during
  // transition); drop in Phase 2 cleanup once readers migrate to Deal-side
  // (per PRD §5 reader-migration deferral list).
  // microObjectiveProgress DROPPED by KAN-791 — moved to Deal.microObjectiveProgress
  // (pre-flight #4 verified 0 prod contacts had non-default values).
  currentPipelineId String?        @map("current_pipeline_id")
  currentStageId    String?        @map("current_stage_id")
  enteredStageAt    DateTime?      @map("entered_stage_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  contactObjectiveStack ContactObjectiveStack[]
  decisions             Decision[]
  outcomes              Outcome[]
  customer              Customer?
  conversations         Conversation[]
  escalations           Escalation[]
  actions               Action[]
  currentPipeline       Pipeline?               @relation("ContactCurrentPipeline", fields: [currentPipelineId], references: [id], onDelete: SetNull)
  currentStage          Stage?                  @relation("ContactCurrentStage", fields: [currentStageId], references: [id], onDelete: SetNull)
  // KAN-791 — LeadStageHistory dropped (replaced by DealStageHistory which is deal-scoped)
  deals                 Deal[]
  engagements           Engagement[]
  deferredSends         DeferredSend[]
  // KAN-879
  company               Company?                @relation(fields: [companyId], references: [id])
  orders                Order[]
  // KAN-1001 Campaign Slice 0 — Contact ↔ CampaignMembership back-relation.
  campaignMemberships   CampaignMembership[]
  // M3-1 Sub-Objective Framework MVP — discovery checkpoints per contact.
  // Cascading delete: removing a contact removes its gap-state rows.
  subObjectiveGapStates ContactSubObjectiveGapState[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, lifecycleStage])
  @@index([tenantId, segment])
  @@index([tenantId, dataQualityScore])
  @@index([tenantId, source])
  @@index([tenantId, currentPipelineId])
  @@index([tenantId, currentStageId])
  @@index([tenantId, companyId])
  @@index([tenantId, country, region])
  @@map("contacts")
}

// KAN-959 — ContactState decommissioned (slice 1 of Objectives → AI Pipeline).
// Replaced by ContactObjectiveStack (per-entity narrow table, prioritized + combinable).
// Drop gated on empty-row check at migration time; ContactState had 0 writers in code.
//
// Slice 1 introduces ContactObjectiveStack. Order/Company variants land in slice 5
// using the same shape (per-entity narrow tables, not polymorphic). The shared
// objective-stack-repo at packages/api/src/services/objective-stack-repo.ts
// keeps cross-entity ops (priority, fallback, gap roll-up) in one place.
model ContactObjectiveStack {
  id              String                      @id @default(uuid())
  tenantId        String                      @map("tenant_id")
  contactId       String                      @map("contact_id")
  objectiveId     String                      @map("objective_id")
  // KAN-1001 Campaign Slice 0 — provenance for new stack entries created
  // from a Campaign activation (Slice 3 commit flow). Nullable so the
  // backfill doesn't touch existing rows (they predate Campaign and
  // continue working via the un-namespaced priority logic). Slice 3's
  // Campaign commit populates this for new entries.
  campaignId      String?                     @map("campaign_id")
  // Lower priority = higher rank. 1 = primary, 2 = secondary, …
  priority        Int
  status          ContactObjectiveStackStatus @default(active)
  // Per-entity sub-objective progress map. Same shape as legacy
  // ContactState.subObjectives Json (carried forward unchanged).
  subObjectives   Json                        @default("[]") @map("sub_objectives")
  strategyCurrent String?                     @map("strategy_current")
  confidenceScore Float?                      @map("confidence_score")
  achievedAt      DateTime?                   @map("achieved_at")
  blockedReason   String?                     @map("blocked_reason")
  blockedSinceAt  DateTime?                   @map("blocked_since_at")
  activatedAt     DateTime                    @default(now()) @map("activated_at")
  lastEvaluatedAt DateTime                    @default(now()) @map("last_evaluated_at")
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  objective Objective @relation(fields: [objectiveId], references: [id])
  // KAN-1001 — Campaign back-link (Phase 2 readers will join through this
  // when Slice 3 starts populating campaign_id for new entries).
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([contactId, objectiveId])
  @@index([tenantId, contactId, priority])
  @@index([tenantId, status])
  // KAN-1001 — Phase 2 routing reads through this index.
  @@index([tenantId, campaignId, priority])
  @@map("contact_objective_stack")
}

enum ContactObjectiveStackStatus {
  active
  paused
  blocked
  achieved
  abandoned
  superseded

  @@map("contact_objective_stack_status")
}

// ─────────────────────────────────────────────
// DECISION ENGINE (DECIDE phase)
// ─────────────────────────────────────────────

model Objective {
  id               String                @id @default(uuid())
  tenantId         String                @map("tenant_id")
  name             String
  // Free-form string (NOT the ObjectiveType enum — see schema-claims discipline
  // note in KAN-959). The Pipeline.objectiveType enum is parallel + scoped to
  // the 4 legacy seed values; the catalog seeded here uses a broader
  // 8-value vocabulary (book_appointment, sell_online, enrich_lead, warm_up,
  // reactivate, retain_customer, upsell, recover_failed_payment). Taxonomy
  // consolidation deferred to a later slice.
  type             String
  successCondition Json                  @map("success_condition")
  subObjectives    Json                  @default("[]") @map("sub_objectives")
  blueprintId      String?               @map("blueprint_id")
  // KAN-959 — entity scope (which entity type pursues this objective).
  // Slice 1 writes `contact` only; the column carries all 4 values so slice 5
  // (Order/Company stacks) can adopt without a migration.
  entityScope      ObjectiveEntityScope? @map("entity_scope")
  // KAN-959 — provenance of the row. blueprint_generic for the catalog seed;
  // future slices add the other values when the AI proposer + human-authored
  // paths land.
  source           ObjectiveSource?
  isActive         Boolean               @default(true) @map("is_active")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  tenant                Tenant                     @relation(fields: [tenantId], references: [id])
  blueprint             Blueprint?                 @relation(fields: [blueprintId], references: [id])
  contactObjectiveStack ContactObjectiveStack[]
  outcomes              Outcome[]
  // KAN-959 — Pipeline.objectiveId binding (Pipeline → Objective; Pipeline =
  // the structured path to its bound Objective).
  pipelines             Pipeline[]
  // KAN-959 — MicroObjective reverse-relation. MicroObjective remains a
  // reusable gate definition; per-entity progress lives on the stack row.
  microObjectives       MicroObjective[]
  // KAN-962 (slice 2a) — tenant-level prioritized selection back-relation
  tenantSelections      TenantObjectiveSelection[]
  // KAN-1001 Campaign Slice 0 — Campaign.objectiveId binding (Campaign =
  // intent layer ABOVE Pipeline; one Objective → many Campaigns). Restrict
  // delete posture mirrors TenantObjectiveSelection — you don't drop an
  // Objective with live Campaigns hanging off it.
  campaigns             Campaign[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, entityScope])
  @@map("objectives")
}

// ─────────────────────────────────────────────
// CAMPAIGN LAYER (KAN-1001 Slice 0 Phase 1 — additive, dual-read)
//
// Architect/PO greenlit per the Campaign Layer epic (KAN-996). Campaign
// owns intent (audience + objective + window + status + priority);
// Pipeline keeps stage structure + gains a nullable campaign_id
// back-link. Phase 1 is purely additive — readers (lead-assignment
// Tier 1.5) untouched, still reading Pipeline.objectiveId + segment.
// Phase 2 (separate ticket) cuts routing to Campaign + drops the
// Pipeline columns.
//
// Reuse insight: audience_conditions jsonb shape = the
// AudienceConditionsSchema that Slice 1 (KAN-997) shipped in
// @growth/shared. Text-to-segment / propose write the same jsonb a
// future manual condition-builder would. Single storage format.
// ─────────────────────────────────────────────

model Campaign {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  // Intent
  name        String
  // KAN-1001 — original NL goal for durable re-runnability + accuracy
  // review on COMMITTED campaigns. Complementary to the Slice 1 Cloud
  // Logging line (jsonPayload.type='text_to_segment' / 'campaign_propose')
  // which captures TRANSIENT proposals the user previewed-but-didn't-
  // commit. Both surfaces matter for text-to-segment quality review.
  nlIntent    String?           @map("nl_intent")
  objectiveId String            @map("objective_id")
  // 4 user-facing strategies (the 6-value StrategyType enum's escalate +
  // wait are decision-engine control-flow primitives, not campaign
  // strategies). Nullable — committed without explicit strategy = default
  // behavior at execution time.
  strategy    CampaignStrategy?

  // Audience
  // jsonb shape = AudienceConditionsSchema in @growth/shared
  // (PAIRS-tested enums after KAN-1000 fix-forward; recursive
  // discriminated union of allOf/anyOf over typed leaf conditions).
  audienceConditions             Json                 @map("audience_conditions")
  audienceMode                   CampaignAudienceMode @default(static) @map("audience_mode")
  // Slice 5 dynamic-mode cron sets this on each re-eval cycle. Column
  // shipped in Slice 0 so the cron landing in Slice 5 doesn't require
  // another migration.
  audienceEvaluatedAt            DateTime?            @map("audience_evaluated_at")
  audienceSnapshotCount          Int?                 @map("audience_snapshot_count")
  // SUM(Order.grandTotal WHERE contact matches AND currency='USD') at
  // activation. Snapshot — orders aging out of the window after
  // activation don't shift this value. NOT a forecast.
  historicalValueUsdAtActivation Decimal?             @map("historical_value_usd_at_activation") @db.Decimal(14, 2)

  // Window
  windowStart DateTime? @map("window_start")
  windowEnd   DateTime? @map("window_end")

  // Lifecycle
  status      CampaignStatus @default(draft)
  // Lower = higher rank. Default 100 leaves room for human + AI to
  // inject hi/lo priority campaigns without renumbering existing ones.
  priority    Int            @default(100)
  activatedAt DateTime?      @map("activated_at")
  completedAt DateTime?      @map("completed_at")
  archivedAt  DateTime?      @map("archived_at")

  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict — you can't drop an Objective with live Campaigns hanging off it.
  // Mirrors TenantObjectiveSelection.objective relation posture.
  objective    Objective               @relation(fields: [objectiveId], references: [id], onDelete: Restrict)
  pipelines    Pipeline[]
  memberships  CampaignMembership[]
  stackEntries ContactObjectiveStack[]

  @@index([tenantId, status])
  @@index([tenantId, objectiveId])
  // Slice 5 dynamic-cron filter: pick active+dynamic campaigns due for re-eval.
  @@index([tenantId, status, audienceMode])
  @@map("campaigns")
}

model CampaignMembership {
  id         String               @id @default(uuid())
  tenantId   String               @map("tenant_id")
  campaignId String               @map("campaign_id")
  contactId  String               @map("contact_id")
  source     CampaignMemberSource
  joinedAt   DateTime             @default(now()) @map("joined_at")
  exitedAt   DateTime?            @map("exited_at")
  // Free-form reason — typically "window_ended", "audience_no_longer_matches",
  // "manual_remove", or NULL while still active.
  exitReason String?              @map("exit_reason")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // One row per (campaign, contact) — re-admit after exit reuses + updates
  // exitedAt/exitReason rather than creating a duplicate.
  @@unique([campaignId, contactId])
  @@index([tenantId, campaignId])
  @@index([tenantId, contactId])
  @@map("campaign_membership")
}

enum CampaignStrategy {
  direct
  re_engage
  trust_build
  guided

  @@map("campaign_strategy")
}

enum CampaignAudienceMode {
  // Materialize matching contacts once at activation. Historical sets
  // ("spring 2024 buyers") never grow.
  static
  // Re-evaluate audience_conditions on schedule (Slice 5 cron). New
  // qualifiers admitted via CampaignMembership.source='dynamic_admit'.
  dynamic

  @@map("campaign_audience_mode")
}

// NOTE: Tenant.dailyLlmCostCapUsd added by KAN-1009 SAE PR4 — see the
// Tenant model section above for the column definition.

enum CampaignStatus {
  draft // proposed but not committed; not routed to
  // KAN-1004 SAE PR1 — INERT post-commit state. Membership snapshot exists,
  // Pipeline + Stages exist, but NO autonomous consumer evaluates members
  // (no decision.run publish, no stack push). Slice 3a's actual semantics;
  // until this enum value existed, 3a wrote `active` which was a misnomer.
  committed
  active // engine-active: Slice 3b activation pushed stack entries; consumer evaluates members
  // KAN-1004 SAE PR1 — engine halted. Stack entries also flipped to
  // ContactObjectiveStackStatus='paused' so the consumer skips them.
  // The "stop lever" the brief requires; unused until Slice 3b ships.
  paused
  completed // window_end reached; in-flight finishes, no new admits
  archived // hidden from UI; preserved for outcome learning

