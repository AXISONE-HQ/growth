/// KAN-962 (slice 2a) — tenant-level prioritized objective declaration.
/// Per slice-2 Phase-1 audit Option (ii): clean separation between the
/// `objectives` catalog (per-tenant inventory of what objectives exist)
/// and this table (which objectives the tenant has actually selected and
/// in what priority order, per entity scope).
///
/// Unique constraint on `(tenantId, objectiveId, entityScope)`: same
/// Objective can be selected by multiple tenants AND by the same tenant
/// for multiple entity scopes (a tenant might rank book_appointment as
/// primary for contacts AND for orders), but NOT twice for the same
/// (tenant, objective, scope) tuple.
///
/// `priority` is an integer; lower = higher rank. Slice 2a's UI enforces
/// 1 = primary (single-row per tenant per entity scope, free-tier
/// gating), but the schema allows 2/3/… for slice-2b+ multi-primary
/// tiers.
///
/// `status='selected'` is the normal state. `'archived'` keeps the row
/// for audit but excludes from active reads (lead-assignment tier 1.5,
/// future Brain objective-awareness). `'pending_review'` reserved for
/// AI-proposed-but-not-yet-adopted cases.
model TenantObjectiveSelection {
  id          String               @id @default(uuid())
  tenantId    String               @map("tenant_id")
  objectiveId String               @map("objective_id")
  entityScope ObjectiveEntityScope @map("entity_scope")
  priority    Int
  status      String               @default("selected")
  adoptedAt   DateTime             @default(now()) @map("adopted_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Restrict)

  @@unique([tenantId, objectiveId, entityScope])
  @@index([tenantId, entityScope, priority])
  @@index([tenantId, status])
  @@map("tenant_objective_selection")
}

model Decision {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  contactId        String   @map("contact_id")
  strategySelected String   @map("strategy_selected")
  actionType       String   @map("action_type")
  confidence       Float
  reasoning        String?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  contact          Contact            @relation(fields: [contactId], references: [id])
  actions          Action[]
  // KAN-791 — replaced LeadStageHistory[] with DealStageHistory[] (deal-scoped)
  dealStageHistory DealStageHistory[]
  escalations      Escalation[]
  // M3-2.5a — back-relation for engagements.decision_id FK.
  engagements      Engagement[]

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, createdAt])
  @@map("decisions")
}

