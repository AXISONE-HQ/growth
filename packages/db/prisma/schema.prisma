// ─────────────────────────────────────────────

// KAN-742 — Sprint 3 / S3.8 Lead API.
// Tenant-scoped API keys for the public POST /api/v1/leads endpoint.
// Plaintext key is `axone_live_<32hex>`; we store keyPrefix (first 12 hex of
// the entropy portion — NOT including brand prefix) and bcrypt-hashed
// remainder. Lookup is O(1) via the keyPrefix index; bcrypt only runs
// against the matched candidate row.
// Plaintext is shown ONCE at creation time — server NEVER returns it after,
// not even via admin endpoints.
model TenantApiKey {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  name       String
  // First 12 hex chars of the entropy portion (after stripping `axone_live_`).
  // 48 bits → genuinely O(1) indexed lookup per request.
  keyPrefix  String    @map("key_prefix")
  // bcrypt of the remaining 20 hex chars.
  keyHash    String    @map("key_hash")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  revokedBy  String?   @map("revoked_by")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([keyPrefix])
  @@index([tenantId, revokedAt])
  @@map("tenant_api_keys")
}

// KAN-741 — Sprint 3 / S3.11 Lead Inbox.
// Audit + idempotency row written on every inbound webhook hit (accepted,
// rejected_spam, rejected_unverified). The resend_email_id unique constraint
// is the dedup key; Redis dedup gives us short-window dedup, this gives us
// permanent dedup persistent across container restarts.
model LeadInboxEvent {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  inboxAddress     String   @map("inbox_address")
  resendEmailId    String?  @unique @map("resend_email_id")
  fromAddress      String   @map("from_address")
  subject          String?
  bodyPreview      String?  @map("body_preview")
  attachmentCount  Int      @default(0) @map("attachment_count")
  spfPass          Boolean  @map("spf_pass")
  dkimPass         Boolean  @map("dkim_pass")
  // 'received' | 'rejected_spam' | 'rejected_unverified' |
  // 'rejected_unknown_slug' | 'rejected_autoresponder' | 'accepted'
  // (TS union at apps/connectors/src/webhooks/resend-inbound.ts is the
  // authoritative source; this column is plain TEXT with no DB enum)
  status           String
  rejectionReason  String?  @map("rejection_reason")
  createdContactId String?  @map("created_contact_id")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@map("lead_inbox_events")
}

// KAN-738 — Sprint 3 / S3.1 agentic loop seam.
// One row per shadow-mode comparison run. Live mode (Tenant.agentic_mode_enabled
// = true) does NOT write to this table — only the agentic Decision row is
// persisted via the standard Decision model. Shadow mode is the default.
model AgenticShadowDecision {
  id                     String   @id @default(uuid())
  tenantId               String   @map("tenant_id")
  contactId              String   @map("contact_id")
  // FK to Decision row from the rules-based path (always set in shadow mode
  // because rules-based always runs first and emits action.decided).
  decisionId             String?  @map("decision_id")
  agenticDecisionPayload Json     @map("agentic_decision_payload")
  rulesDecisionPayload   Json     @map("rules_decision_payload")
  // Bounded set — see DivergenceFlag in @growth/shared/decision-payload.ts.
  divergenceFlags        String[] @map("divergence_flags")
  // Set when divergence_flags includes 'agentic_error'. Indexable for
  // "all failed agentic runs in window X" queries (KAN-745 follow-up will
  // build observability on top of this).
  agenticError           String?  @map("agentic_error")
  createdAt              DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, contactId])
  @@index([tenantId, agenticError])
  @@map("agentic_shadow_decisions")
}

model Action {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  decisionId   String    @map("decision_id")
  contactId    String    @map("contact_id")
  agentType    String    @map("agent_type")
  channel      String?
  payload      Json      @default("{}")
  status       String    @default("pending")
  sentAt       DateTime? @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  failedAt     DateTime? @map("failed_at")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  decision Decision @relation(fields: [decisionId], references: [id])
  contact  Contact  @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([decisionId])
  @@map("actions")
}

