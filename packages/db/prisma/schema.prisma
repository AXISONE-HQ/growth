// ─────────────────────────────────────────────────────────────
// APPEND TO: packages/db/prisma/schema.prisma
//
// Adds the ChannelConnection model for the Connectors Service.
// See Jira KAN-477 and ADR-007 (Extract Connectors Service).
//
// Migration: `npm run -w @growth/db push` (dev)
//            or `prisma migrate dev --name add_channel_connections`
// ─────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────
// CONNECTORS — Channel Connections per tenant
// ─────────────────────────────────────────────────────────────
model ChannelConnection {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  channelType       ChannelType      @map("channel_type")
  provider          String           // "twilio" | "resend" | "meta" | ...
  providerAccountId String           @map("provider_account_id") // subaccount SID / subuser / page ID
  status            ConnectionStatus @default(PENDING)
  label             String?          // human-readable display label (e.g. "Twilio SMS", "Messenger - <page>")
  credentialsRef    String           @map("credentials_ref") // Secret Manager path
  metadata          Json             @default("{}")
  complianceStatus  Json?            @map("compliance_status") // 10DLC, domain auth, app review
  connectedAt       DateTime?        @map("connected_at")
  lastHealthCheck   DateTime?        @map("last_health_check")
  healthStatus      String?          @map("health_status")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  tenant            Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, channelType, providerAccountId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, channelType])
  @@map("channel_connections")
}

enum ChannelType {
  SMS
  EMAIL
  MESSENGER
  WHATSAPP

  @@map("channel_type")
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
  ERROR

  @@map("connection_status")
}

// ─────────────────────────────────────────────────────────────
// EMAIL SUPPRESSIONS — per-tenant (bounces, unsubscribes, spam)
// KAN-661
// ─────────────────────────────────────────────────────────────
model EmailSuppression {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  email     String
  reason    String   // 'bounce' | 'spam' | 'unsubscribed' | 'manual'
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("email_suppressions")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATION PREFERENCES — per-user per-tenant per-type toggle
// KAN-454
// ─────────────────────────────────────────────────────────────
model NotificationPreference {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id") // Firebase UID; 'unknown' fallback for unauthenticated dev contexts
  type      String   // 'escalation' | 'daily_digest' | 'weekly_report' | 'brain_update'
  enabled   Boolean
  channel   String   @default("email")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, userId, type])
  @@index([tenantId, userId])
  @@map("notification_preferences")
}

