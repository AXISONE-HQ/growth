/// KAN-962 (slice 2a) — append-only customer-lifecycle audit. PR A creates
/// the table; PR B adds the one writer hook (stage-transition-engine.ts
/// terminal_won → upsert Customer + log eventType='created'). No
/// status-automation, no standards engine, no slicing this slice — just
/// start recording what naturally happens so slice-4 (Brain objective-aware
/// loop) and slice-2b (daily scheduled discovery) have a lifecycle signal
/// to count.
///
/// Append-only: rows never updated/deleted. Status transitions reconstruct
/// by reading the latest event for (tenantId, contactId).
model CustomerLifecycleEvent {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  contactId  String   @map("contact_id")
  /// Customer row id when known (created/upserted at the same moment).
  /// Nullable for the rare case where lifecycle events log before the
  /// Customer row exists (defensive — PR B's hook upserts first).
  customerId String?  @map("customer_id")
  /// Bounded set: `created` | `activated` | `at_risk_flagged` | `churned`
  /// | `renewed` | `reactivated`. Free-string in schema to avoid enum
  /// migration churn; enforce at the writer.
  eventType  String   @map("event_type")
  fromStatus String?  @map("from_status")
  toStatus   String?  @map("to_status")
  /// What event upstream caused the lifecycle change. Bounded set:
  /// `deal_won` | `deal_lost` | `order_paid` | `order_cancelled` |
  /// `manual` | `sync` | `cron`. Free-string at the schema layer.
  source     String
  metadata   Json     @default("{}")
  recordedAt DateTime @default(now()) @map("recorded_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId, contactId, recordedAt])
  @@index([tenantId, eventType, recordedAt])
  @@map("customer_lifecycle_event")
}

model Conversation {
  id            String    @id @default(uuid())
