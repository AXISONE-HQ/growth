// ─────────────────────────────────────────────
// KAN-700: Pipelines, Stages, MicroObjectives, Targets, Guardrails,
// KnowledgeFilters, LeadStageHistory
//
// Replaces the legacy Pipeline + PipelineCard pair (dropped in this same
// migration; both 0 rows in prod, dead-code consumer pipelinesRouter
// removed in same PR). New design: Stage as a first-class table (was a
// JSON blob inside the legacy Pipeline), and per-Lead pipeline state lives
// on Contact.currentPipelineId/currentStageId (was the PipelineCard table).
// ─────────────────────────────────────────────

enum ObjectiveType {
  warm_up_lead
  book_appointment
  buy_online
  send_quote

  @@map("objective_type")
}

enum TargetMetric {
  appointments_booked
  orders_placed
  quotes_sent
  replies_received
  leads_qualified
  revenue_dollars

  @@map("target_metric")
}

enum TargetPeriod {
  weekly
  monthly
  quarterly

  @@map("target_period")
}

enum ValidatorType {
  tone
  accuracy
  hallucination
  compliance
  injection

  @@map("validator_type")
}

enum GuardrailSeverity {
  block
  regenerate
  warn
  pass

  @@map("guardrail_severity")
}

enum KnowledgeCategory {
  company_info
  products
  warranty
  shipping
  financing
  faqs

  @@map("knowledge_category")
}

model Pipeline {
  id                       String           @id @default(uuid())
  tenantId                 String           @map("tenant_id")
  name                     String
  description              String?
  isActive                 Boolean          @default(true) @map("is_active")
  order                    Int              @default(0)
  objectiveType            ObjectiveType    @map("objective_type")
  objectiveDescription     String?          @map("objective_description")
  // KAN-959 — Pipeline binds to an Objective row (Pipeline = the path to the
  // Objective). Nullable during slice 1: the fixture pipeline (KAN-702 Verify
  // Pipeline) stays NULL per Phase 1 strict-fixture decision. The legacy
  // `objectiveType` enum + `objectiveDescription` columns remain parallel
  // this slice; consolidation deferred.
  objectiveId              String?          @map("objective_id")
  // KAN-962 (slice 2a) — segment marker. Distinguishes pipelines that serve
  // different audiences of the SAME objective (a tenant pursuing
  // book_appointment may have a `new_leads` pipeline AND a `closed_lost_recovery`
  // pipeline both bound to the same Objective row). Tier 1.5 routing in
  // lead-assignment filters on (segment=new_leads, objectiveId=<primary>) so
  // future winback pipelines never catch fresh inbound. Nullable for back-compat
  // with KAN-702 fixture + pre-slice-2a pipelines.
  segment                  PipelineSegment? @map("segment")
  // KAN-704: pipeline-tier auto-approve defaults. Resolution order is
  // Stage.autoApproveMatrix → this column → Tenant.autoApproveEnabled
  // (kill-switch) → platform default (auto-approve-defaults.ts). NULL means
  // "skip this tier" (same posture as Stage.autoApproveMatrix when empty).
  defaultAutoApproveMatrix Json?            @map("default_auto_approve_matrix")
  // KAN-1001 Campaign Slice 0 — back-link to the owning Campaign. NULLABLE
  // in Phase 1 because (a) the backfill migration populates this for every
  // objective-bound Pipeline; (b) the legacy fixture Pipeline (KAN-702
  // Verify Pipeline) has objectiveId=NULL so its backfill skips → stays
  // NULL until/unless reassigned. Phase 2 cuts lead-assignment routing
  // over to read Campaign instead of Pipeline.objectiveId+segment.
  campaignId               String?          @map("campaign_id")
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")

  tenant           Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages           Stage[]
  microObjectives  PipelineMicroObjective[]
  targets          Target[]
  guardrails       Guardrail[]
  knowledgeFilters KnowledgeFilter[]
  assignmentRules  AssignmentRule[]
  contacts         Contact[]                @relation("ContactCurrentPipeline")
  // KAN-791 — Deal lifecycle relation
  deals            Deal[]
  // KAN-959 — Objective binding (retire in Phase 2 — Campaign owns this)
  objective        Objective?               @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  // KAN-1001 Campaign Slice 0 — Campaign binding (Phase 2 promotes this
  // to the primary objective-resolution path; Phase 1 dual-reads).
  campaign         Campaign?                @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, objectiveType])
  @@index([objectiveId])
  // KAN-962 — tier 1.5 routing in lead-assignment hits this index every
  // inbound lead: (tenant, objective_id, segment) is the lookup shape.
  @@index([tenantId, objectiveId, segment])
  // KAN-1001 — Phase 2 readers will hit this index when joining Pipeline
  // → Campaign for routing. Cheap to ship now (additive index).
  @@index([campaignId])
  @@map("pipelines")
}

/// KAN-962 (slice 2a) — segment marker for pipelines that serve different
/// audiences of the same Objective. New segments append-only; old enum values
/// never removed (the migration policy mirrors KAN-737 enum-drift discipline).
enum PipelineSegment {
  new_leads
  winback
  closed_lost_recovery
  cancelled_orders_recovery
  inactive_customers_reengagement
  other

  @@map("pipeline_segment")
}

model Stage {
  id                String           @id @default(uuid())
  pipelineId        String           @map("pipeline_id")
  name              String
  order             Int              @default(0)
  isInitial         Boolean          @default(false) @map("is_initial")
  isTerminal        Boolean          @default(false) @map("is_terminal")
  // KAN-791 — outcomeType drives terminal-detection. Phase 2 KAN-796 (Stages
  // Evolution Logic) reads this to know which Stages mark deal closure.
  outcomeType       StageOutcomeType @default(open) @map("outcome_type")
  // KAN-791 — per-Stage follow-up cadence config. Stored in Phase 1; consumer
  // ships in Phase 2 KAN-796 (cron-driven Deal advancement based on signal
  // patterns + cadence). Default platform cadence shipped via the lazy-bootstrap
  // helper (KAN-793 ensureTenantHasDefaultPipeline).
  followUpCadence   Json             @default("{}") @map("follow_up_cadence")
  entryActions      Json             @default("[]") @map("entry_actions")
  transitionRules   Json             @default("[]") @map("transition_rules")
  autoApproveMatrix Json             @default("{}") @map("auto_approve_matrix")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  pipeline          Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  contacts          Contact[]          @relation("ContactCurrentStage")
  // KAN-791 — Deal lifecycle relations replace LeadStageHistory's stage-side relations
  dealsCurrent      Deal[]             @relation("DealCurrentStage")
  dealStageFromHist DealStageHistory[] @relation("DealStageFromHistory")
  dealStageToHist   DealStageHistory[] @relation("DealStageToHistory")

  @@index([pipelineId])
  @@index([pipelineId, order])
  // KAN-791 invariant: at most one isInitial Stage per Pipeline.
  // Prisma's @@unique doesn't support partial indexes — appended as raw SQL
  // in the migration:
  //   CREATE UNIQUE INDEX stages_one_initial_per_pipeline_idx
  //     ON stages (pipeline_id) WHERE is_initial = true;
  @@map("stages")
}

model MicroObjective {
  id                 String   @id @default(uuid())
  // Nullable for platform defaults (KAN-701 seeds 5 platform-default MOs).
  tenantId           String?  @map("tenant_id")
  name               String
  description        String?
  completionCriteria Json     @default("{}") @map("completion_criteria")
  isDefault          Boolean  @default(false) @map("is_default")
  order              Int      @default(0)
  // KAN-959 — reverse-relation to an Objective row. MicroObjective remains
  // a reusable gate definition shared across objectives; per-entity progress
  // lives on ContactObjectiveStack.subObjectives. The PipelineMicroObjective
  // join below stays for backward compatibility with the wizard UX.
  objectiveId        String?  @map("objective_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant    Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  objective Objective?               @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  pipelines PipelineMicroObjective[]

  @@index([tenantId])
  @@index([isDefault])
  @@index([objectiveId])
  @@map("micro_objectives")
}

model PipelineMicroObjective {
  pipelineId       String  @map("pipeline_id")
  microObjectiveId String  @map("micro_objective_id")
  isActive         Boolean @default(true) @map("is_active")

  pipeline       Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  microObjective MicroObjective @relation(fields: [microObjectiveId], references: [id], onDelete: Cascade)

  @@id([pipelineId, microObjectiveId])
  @@index([microObjectiveId])
  @@map("pipeline_micro_objectives")
}

model Target {
  id              String       @id @default(uuid())
  pipelineId      String       @map("pipeline_id")
  metric          TargetMetric
  value           Decimal      @db.Decimal(14, 2)
  period          TargetPeriod
  // Computed by reporting jobs; nullable until first computation.
  currentProgress Decimal?     @map("current_progress") @db.Decimal(14, 2)
  projection      Decimal?     @db.Decimal(14, 2)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, metric, period])
  @@index([pipelineId])
  @@map("targets")
}

model Guardrail {
  id               String             @id @default(uuid())
  tenantId         String             @map("tenant_id")
  // Null = tenant-wide guardrail; non-null = pipeline-scoped override.
  pipelineId       String?            @map("pipeline_id")
  validatorType    ValidatorType      @map("validator_type")
  severityOverride GuardrailSeverity? @map("severity_override")
  isActive         Boolean            @default(true) @map("is_active")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline Pipeline? @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([tenantId, pipelineId, validatorType])
  @@index([tenantId])
  @@index([tenantId, pipelineId])
  @@map("guardrails")
}

model KnowledgeFilter {
  id                String            @id @default(uuid())
  pipelineId        String            @map("pipeline_id")
  knowledgeCategory KnowledgeCategory @map("knowledge_category")
  includeRule       Json              @default("{}") @map("include_rule")
  excludeRule       Json              @default("{}") @map("exclude_rule")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, knowledgeCategory])
  @@index([pipelineId])
  @@map("knowledge_filters")
}

// KAN-705: tenant-defined deterministic rules that route a new lead to a
// specific pipeline. Evaluated tenant-wide on lead creation in priority order
// (lower = higher precedence); first match wins. JSONB conditions keep V1
// flexible while a future ticket can normalize the predicate language.
//
// Hot path query: `findMany({ where: { tenantId, isActive: true }, orderBy:
// { priority: 'asc' } })` — covered by the (tenantId, isActive, priority)
// composite index.
model AssignmentRule {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  pipelineId String   @map("pipeline_id")
  /// Lower number = higher precedence.
  priority   Int      @default(0)
  /// JSONB predicate matched against Lead fields: source, segment, lifecycleStage, dataQualityScore, email, externalIds.
