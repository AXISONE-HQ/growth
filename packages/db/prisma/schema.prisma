  @@map("stage_outcome_type")
}

/// Phase 1 (KAN-791) — Engagement attached to Deal (dealId REQUIRED).
/// contactId stays as denormalized fast-query field.
model Engagement {
  id             String      @id @default(cuid())
  tenantId       String      @map("tenant_id")
  // KAN-791 — dealId REQUIRED (was implicit/missing). Engagement attaches to Deal;
  // queryable to Contact via the FK chain.
  dealId         String      @map("deal_id")
  contactId      String      @map("contact_id")
  correlationId  String?     @unique @map("correlation_id")
  // M3-2.5a — Decision FK top-level (was buried in metadata Json pre-slice;
  // makes Decision→Engagement queryable + indexable). Nullable for back-
  // compat with engagements whose Decision row was deleted or for non-
  // engine engagements (Lead Inbox pre-correlation, etc.).
  decisionId     String?     @map("decision_id")
  engagementType String      @map("engagement_type")
  signalClass    SignalClass @map("signal_class")
  channel        String?
  metadata       Json        @default("{}")
  occurredAt     DateTime    @map("occurred_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Restrict)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  // M3-2.5a — Decision FK with SET NULL: an Engagement row stays as an
  // audit record of "what happened" even if the originating Decision is
  // ever purged.
  decision Decision? @relation(fields: [decisionId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  // M3-2.5a — 1:1 sidecar holding email-wire metadata (provider, message-
  // id, in-reply-to, references). Only email-type engagements have a row.
  // CASCADE on engagement delete keeps the sidecar in lockstep.
  emailMetadata EngagementEmailMetadata?

  @@index([tenantId, dealId, occurredAt])
  @@index([tenantId, contactId, occurredAt])
  @@index([tenantId, engagementType])
  @@index([tenantId, decisionId])
  @@map("engagements")
}

// M3-2.5a — 1:1 sidecar for email-wire metadata (provider, providerMessageId,
// in_reply_to, references_array). Holds the wire-protocol bits needed for
// the M3-2.5b inbound In-Reply-To → outbound providerMessageId correlation
// lookup. Tenant scope flows transitively through engagement_id →
// engagement.tenant_id (sibling pattern: AccountProfile children — no
// direct tenant_id column, parent FK enforces scope on query). NOT added
// to TENANT_SCOPED_MODELS in tenant middleware for the same reason.
model EngagementEmailMetadata {
  engagementId      String   @id @map("engagement_id")
  // Free-form TEXT not Postgres enum — KNOWN_EMAIL_PROVIDERS in
  // @growth/shared is the reference list (Blueprint loader / sub_objective_key
  // precedent). Enum-grow-by-migration is the trap we're avoiding.
  provider          String
  providerMessageId String   @map("provider_message_id")
  // Inbound-only fields, populated in M3-2.5b. Outbound rows leave null.
  inReplyTo         String?  @map("in_reply_to")
  referencesArray   String[] @map("references_array")
  // KAN-1036 — subaddress-anchored reply correlation token. Outbound rows
  // mint a per-decision 16-char hex token at send time; the outbound
  // Reply-To header becomes `<inboxSlug>+<replyToken>@<DOMAIN>`. When a
  // recipient replies, their MUA addresses to the subaddressed form;
  // Resend Receiving forwards it preserving the +<token>; the consumer
  // parses the token from data.to and looks up THIS column to recover
  // the originating Engagement → Decision → Contact → Deal for the
  // M3-2.5b redirect-shadowed rescue.
  //
  // Replaces the wire-Message-ID-based correlation (Plan A in M3-2.5b),
  // which was empirically falsified — Resend has no API surface that
  // exposes the SES-generated wire Message-ID. KAN-1036 pivots the
  // correlation anchor from "value Resend opaquely owns" to "value WE
  // mint and control at send time."
  //
  // Back-compat callers (cron-deferred-send, deferred-send-evaluator)
  // that don't have a decisionId in scope leave this NULL. The unique
  // index permits multiple NULLs (Postgres semantics — NULL ≠ NULL).
  // The consumer's lookup guards on `if (replyToken)` before querying,
  // so NULL rows are inert.
  replyToken        String?  @unique(map: "engagement_email_metadata_reply_token_idx") @map("reply_token")
  createdAt         DateTime @default(now()) @map("created_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  // Global UNIQUE: providerMessageId is the provider's wire ID — globally
  // unique within the provider's namespace, so cross-tenant collision is
  // structurally impossible. The correlation lookup in M3-2.5b will hit
  // this for O(1) sidecar resolution.
  @@unique([provider, providerMessageId], map: "engagement_email_metadata_provider_provider_message_id_key")
  @@index([inReplyTo], map: "engagement_email_metadata_in_reply_to_idx")
  @@map("engagement_email_metadata")
}

enum SignalClass {
  positive
  negative
  neutral

  @@map("signal_class")
}

// ─────────────────────────────────────────────
// ACCOUNT PAGE — KAN-852 Cohort 1
// Tenant-facing settings page at /settings/account. AccountProfile owns the
// canonical Company Truth fields (identity, contact, hours, payments, legal).
// Children link via accountProfileId — they follow the ChunkEffectiveness
// precedent (no direct tenant_id column; tenant scope flows transitively
// through the parent's tenantId via FK + JOIN). They are deliberately NOT
// added to TENANT_SCOPED_MODELS in packages/db/src/middleware/tenant.ts —
// the auto-inject middleware would try to filter on a non-existent column
// and break every query. See KAN-826 architecture for the same pattern.
// ─────────────────────────────────────────────

model AccountProfile {
  id       String @id @default(cuid())
  tenantId String @unique @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identity
  legalName          String  @map("legal_name")
  displayName        String? @map("display_name")
  logoUrl            String? @map("logo_url")
  logoVariants       Json?   @map("logo_variants")
  websiteUrl         String? @map("website_url")
  oneLineDescription String? @map("one_line_description") @db.VarChar(200)
  industry           String?

  // Contact
  primaryPhone          String? @map("primary_phone")
  supportPhone          String? @map("support_phone")
  primaryEmail          String? @map("primary_email")
  supportEmail          String? @map("support_email")
  physicalAddress       String? @map("physical_address") @db.Text
  mailingAddress        String? @map("mailing_address") @db.Text
  mailingSameAsPhysical Boolean @default(true) @map("mailing_same_as_physical")

  // Address structured (AI-populated, optional)
  addressStreet  String? @map("address_street")
  addressCity    String? @map("address_city")
  addressRegion  String? @map("address_region")
  addressPostal  String? @map("address_postal")
  addressCountry String? @map("address_country")

  // Service area
  serviceAreaType     String @default("local") @map("service_area_type")
  serviceAreaRadiusKm Int?   @map("service_area_radius_km")
  serviceAreaRegions  Json?  @map("service_area_regions")

  // Hours
  timeZone           String @default("America/Toronto") @map("time_zone")
  weeklyHours        Json   @default("{}") @map("weekly_hours")
  afterHoursBehavior String @default("send_anyway") @map("after_hours_behavior")

  // Payments
  defaultCurrency        String   @default("USD") @map("default_currency")
  additionalCurrencies   String[] @default([]) @map("additional_currencies")
  acceptedPaymentMethods String[] @default([]) @map("accepted_payment_methods")
  depositRequired        Boolean  @default(false) @map("deposit_required")
  depositType            String?  @map("deposit_type")
  depositValue           Decimal? @map("deposit_value") @db.Decimal(10, 2)
  refundWindowDays       Int?     @map("refund_window_days")

  // Legal
  taxId                 String? @map("tax_id")
  businessRegNumber     String? @map("business_reg_number")
  jurisdiction          String?
  // KAN-852 — flat tenant override columns. Stored as raw strings (not
  // keyed by language) so most tenants — who operate in one language at
  // a time — get crisp save/clear semantics. The override applies to
  // whatever the tenant's current `defaultLanguage` is at read time;
  // when they switch defaultLanguage, an existing override goes stale
  // (still attached, but possibly in the previous language). Cohort 4
  // Legal tab UI surfaces a "Custom" badge when set and a "Blueprint
  // default" badge when null; clearing the field falls back to
  // Blueprint.legalDefaults via resolveLegalDefaults() in
  // blueprint-loader.ts. Cohort 4 design open question (tracked on
  // Confluence spec §2): per-language override columns vs. flat-with-
  // stale-warning vs. auto-translate.
  optOutLanguage        String? @map("opt_out_language") @db.Text
  emailFooterDisclosure String? @map("email_footer_disclosure") @db.Text

  // Locale
  defaultLanguage    String   @default("en") @map("default_language")
  supportedLanguages String[] @default(["en"]) @map("supported_languages")

  // Detect-from-website state (Cohort 5 wires the worker; columns ship now)
  lastDetectAt     DateTime? @map("last_detect_at")
  lastDetectSource String?   @map("last_detect_source")
  detectStatus     String?   @map("detect_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  socialProfiles      SocialProfile[]
  observedHolidays    ObservedHoliday[]
  industryDisclosures IndustryDisclosure[]
  fieldDetections     AccountFieldDetection[]

  @@index([tenantId])
  @@map("account_profile")
}

// FK-transitive tenant scope (no direct tenant_id) — see ChunkEffectiveness
// precedent at line ~1219. Reads must JOIN to AccountProfile to enforce
// tenant boundary; do NOT add to TENANT_SCOPED_MODELS.
model SocialProfile {
  id               String         @id @default(cuid())
  accountProfileId String         @map("account_profile_id")
  accountProfile   AccountProfile @relation(fields: [accountProfileId], references: [id], onDelete: Cascade)

  platform String
  url      String
  handle   String?
  position Int     @default(0)

  @@index([accountProfileId])
  @@map("social_profile")
}

// FK-transitive tenant scope — see ChunkEffectiveness precedent.
model ObservedHoliday {
  id               String         @id @default(cuid())
  accountProfileId String         @map("account_profile_id")
  accountProfile   AccountProfile @relation(fields: [accountProfileId], references: [id], onDelete: Cascade)

  name      String
  date      DateTime @db.Date
  recurring Boolean  @default(false)

  @@index([accountProfileId, date])
  @@map("observed_holiday")
}

// FK-transitive tenant scope — see ChunkEffectiveness precedent.
model IndustryDisclosure {
  id               String         @id @default(cuid())
  accountProfileId String         @map("account_profile_id")
  accountProfile   AccountProfile @relation(fields: [accountProfileId], references: [id], onDelete: Cascade)

  label             String
  body              String   @db.Text
  appliesToChannels String[] @default([]) @map("applies_to_channels")
  position          Int      @default(0)

  @@index([accountProfileId])
  @@map("industry_disclosure")
}

// FK-transitive tenant scope — see ChunkEffectiveness precedent.
// Cohort 5 worker writes; Cohort 6 UI consumes. Schema lands now to keep
// the migration set atomic.
model AccountFieldDetection {
  id               String         @id @default(cuid())
  accountProfileId String         @map("account_profile_id")
  accountProfile   AccountProfile @relation(fields: [accountProfileId], references: [id], onDelete: Cascade)

  fieldPath     String    @map("field_path")
  proposedValue String    @map("proposed_value") @db.Text
  confidence    Float
  sourceUrl     String?   @map("source_url")
  sourceSnippet String?   @map("source_snippet") @db.Text
  status        String    @default("proposed")
  decidedAt     DateTime? @map("decided_at")
  decidedBy     String?   @map("decided_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([accountProfileId, fieldPath])
  @@index([accountProfileId, status])
  @@map("account_field_detection")
}

