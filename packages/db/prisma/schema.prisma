  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  contact Contact  @relation(fields: [contactId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])

  @@unique([tenantId, orderNumber])
  @@index([tenantId, contactId])
  @@index([tenantId, companyId, placedAt(sort: Desc)])
  @@index([tenantId, dealId])
  @@index([tenantId, status])
  @@index([tenantId, placedAt(sort: Desc)])
  @@map("orders")
}

// ─────────────────────────────────────────────────────────────────────
// INGESTION — KAN-896 Cohort 2.1a (upload backend)
//
// PR 1 of 8 in the Cohort 2 ingestion pipeline. Lands the upload +
// inspection foundation. Future cohort PRs layer entity detection
// (2.2), row-level classification (2.3), field mapping UI (2.4),
// staging tables (2.5), duplicate detection (2.6), and commit + audit
// + Pub/Sub fanout (2.7) on top of this model.
//
// Status state machine:
//   awaiting_upload → uploaded → inspecting → inspected
//                                          ↘ failed
//
// Inspection (sync in V1) populates detectedFileType + detectedHeaders +
// sampleRows so the future field-mapping UI can drive the Haiku
// column-to-schema mapping (csv-import-haiku-mapping.ts) without a
// second roundtrip.
// ─────────────────────────────────────────────────────────────────────

enum ImportMode {
  replace_all
  update_add

  @@map("import_mode")
}

enum ImportStatus {
  awaiting_upload
  uploaded
  inspecting
  inspected
  failed

  @@map("import_status")
}

enum ImportFileType {
  csv
  xlsx
  unknown

  @@map("import_file_type")
}

// KAN-904 — Ingestion Cohort 2.2. AI-detected entity type for an
// uploaded file. `unknown` is the conservative coercion when the LLM
// confidence is below the 50% threshold — the LLM's preferred type
// is preserved in `detectionReasoning` text for the operator to
// review manually.
enum DetectedEntityType {
  contacts
  companies
  deals
  orders
  mixed
  unknown

  @@map("detected_entity_type")
}

// KAN-913 — Ingestion Cohort 2.7. Commit phase state machine.
//   pending    — dedup confirmed, commit not yet started
//   running    — runCommit is iterating staging rows
//   succeeded  — all eligible rows committed; commitErrors == []
//   partial    — some rows committed, some in commitErrors
//   failed     — commit aborted (DB error, or 0 successful commits)
enum ImportCommitStatus {
  pending
  running
  succeeded
  partial
  failed

  @@map("import_commit_status")
}

model ImportJob {
  id              String @id @default(cuid())
  tenantId        String @map("tenant_id")
  createdByUserId String @map("created_by_user_id")

  // Upload metadata (captured at createUploadUrl).
  fileName      String @map("file_name")
  fileSize      Int    @map("file_size")
  fileMimeType  String @map("file_mime_type")
  /// `tenants/{tenantId}/imports/{importJobId}/{filename}` —
  /// tenant-scope check (`startsWith`) enforced before any GCS op.
  gcsObjectPath String @map("gcs_object_path")

  // Mode flag — honored by the future commit cohort (PR 8); captured here
  // so the choice is durable from the moment of upload.
  mode ImportMode @default(update_add)

  // Status state machine.
  status ImportStatus @default(awaiting_upload)

  // Inspection results (populated by inspect logic; null until inspected).
  detectedFileType    ImportFileType? @map("detected_file_type")
  detectedRowCount    Int?            @map("detected_row_count")
  detectedColumnCount Int?            @map("detected_column_count")
  /// Array<string> — populated by inspect logic.
  detectedHeaders     Json?           @map("detected_headers")
  /// Array<Record<string, unknown>> — first 5 data rows.
  sampleRows          Json?           @map("sample_rows")

  // KAN-904 — Ingestion Cohort 2.2. AI entity detection (Haiku via
  // llm-client tier='cheap'). Populated by `runEntityDetection`
  // service when the user clicks "Run detection" on the file detail
  // page. Detection is gated on status='inspected' but does not change
  // status — it's an additive enrichment of an already-inspected job.
  //
  // NOTE: detectionInputTokens / detectionOutputTokens / detectionLlmModel
  // are denormalized snapshots for fast UI display. The canonical cost
  // source is the `llm.call` Pub/Sub topic emitted by
  // llm-client.complete() (KAN-734/745). These three values come from
  // the same complete() response — they MUST NOT diverge.
  detectedEntityType    DetectedEntityType? @map("detected_entity_type")
  /// 0-100 (loose Int; service validates 0..100 before write).
  detectionConfidence   Int?                @map("detection_confidence")
  /// 2-3 sentences from the LLM explaining the classification. When
  /// confidence < 50 and we coerce detectedEntityType to 'unknown',
  /// the LLM's original preferred type is preserved in this text.
  detectionReasoning    String?             @map("detection_reasoning")
  detectionStartedAt    DateTime?           @map("detection_started_at")
  /// Set on success only.
  detectionCompletedAt  DateTime?           @map("detection_completed_at")
  detectionError        String?             @map("detection_error")
  /// Mirrors the inspection.errorAt convention — set on failure only.
  detectionErrorAt      DateTime?           @map("detection_error_at")
  detectionInputTokens  Int?                @map("detection_input_tokens")
  detectionOutputTokens Int?                @map("detection_output_tokens")
  /// Verbatim `response.model` from llm-client.complete() — e.g.
  /// "claude-haiku-4-5-20251001". Stored as-is so the UI footer can
  /// surface exactly which model produced the classification.
  detectionLlmModel     String?             @map("detection_llm_model")

  // KAN-905 — Ingestion Cohort 2.4. AI-suggested column-to-field
  // mapping. Populated by runFieldMapping after the user clicks
  // "Run AI mapping" on /imports/[id]/mapping. Gated on
  // detectedEntityType ∈ {contacts, companies, deals, orders};
  // mixed + unknown return BAD_REQUEST in V1.
  //
  // Token + model snapshots follow the same denormalization rules as
  // detection (see comment above) — canonical cost source remains
  // the `llm.call` Pub/Sub topic.
  //
  // Shape of fieldMappings JSON:
  //   [{ sourceColumn: string, targetField: string, confidence: number|null }, ...]
  // where targetField is either a schema column name in the entity's
  // field universe OR the sentinel 'skip'. confidence is 0-100 (null
  // for 'skip' rows).
  /// JSON array of { sourceColumn, targetField, confidence }.
  fieldMappings            Json?     @map("field_mappings")
  /// Average of non-skip confidences (0-100). NULL if all rows skipped.
  fieldMappingConfidence   Int?      @map("field_mapping_confidence")
  /// LLM's overall reasoning for the mapping suggestions.
  fieldMappingReasoning    String?   @map("field_mapping_reasoning")
  fieldMappingStartedAt    DateTime? @map("field_mapping_started_at")
  /// Set on success only.
  fieldMappingCompletedAt  DateTime? @map("field_mapping_completed_at")
  fieldMappingError        String?   @map("field_mapping_error")
  fieldMappingErrorAt      DateTime? @map("field_mapping_error_at")
  fieldMappingInputTokens  Int?      @map("field_mapping_input_tokens")
  fieldMappingOutputTokens Int?      @map("field_mapping_output_tokens")
  fieldMappingLlmModel     String?   @map("field_mapping_llm_model")
  /// Set when the operator clicks Save on the mapping review page.
  /// Differs from fieldMappingCompletedAt (which is the AI-run
  /// timestamp): a job can have AI-suggested mappings but no operator
  /// confirmation yet.
  fieldMappingConfirmedAt  DateTime? @map("field_mapping_confirmed_at")

  // KAN-907 — Ingestion Cohort 2.3. Row-level classification (hybrid
  // heuristic + LLM batches). Writes to ImportStaging{Contact|Company|
  // Deal|Order} tables. Populated by `runRowClassification` after the
  // user clicks "Classify rows" on the file detail page. Gated on
  // status='inspected' AND detectedEntityType IS NOT NULL.
  //
  // Token + model snapshots follow the same denormalization rules as
  // detection + mapping (see comments above) — canonical cost source
  // remains the `llm.call` Pub/Sub topic. Single-entity uploads
  // (detectedEntityType != 'mixed') skip the LLM entirely; their
  // *InputTokens / *OutputTokens / *LlmModel stay NULL.
  //
  // Shape of rowClassificationCounts JSON:
  //   {
  //     total: number,
  //     byEntity: { contacts, companies, deals, orders, skipped, unknown },
  //     bySource: { heuristic, llm },
  //     lowConfidenceFlags: number
  //   }
  /// JSON aggregate counts (see comment above).
  rowClassificationCounts       Json?     @map("row_classification_counts")
  rowClassificationStartedAt    DateTime? @map("row_classification_started_at")
  /// Set on success only.
  rowClassificationCompletedAt  DateTime? @map("row_classification_completed_at")
  rowClassificationError        String?   @map("row_classification_error")
  rowClassificationErrorAt      DateTime? @map("row_classification_error_at")
  rowClassificationInputTokens  Int?      @map("row_classification_input_tokens")
  rowClassificationOutputTokens Int?      @map("row_classification_output_tokens")
  rowClassificationLlmModel     String?   @map("row_classification_llm_model")
  /// Set when the operator clicks Confirm on Card 5.
  rowClassificationConfirmedAt  DateTime? @map("row_classification_confirmed_at")

  // KAN-911 — Ingestion Cohort 2.6. Duplicate detection (rule-based +
  // Levenshtein, no LLM). For each staging row, runDuplicateDetection
  // finds candidate matches in the canonical entity tables and writes
  // a MatchDecision JSON to ImportStaging{Contact|Company|Deal|Order}.
  // matchDecision. Gated on rowClassificationConfirmedAt IS NOT NULL.
  //
  // Shape of dedupCounts JSON:
  //   {
  //     byEntity: {
  //       contacts:  { total, exactMatches, fuzzyMatches, needsReview, insertOnly },
  //       companies: { ... },
  //       deals:     { ... },
  //       orders:    { ... },
  //     },
  //     candidatesScanned: { contacts: N, companies: M, ... }
  //   }
  dedupStartedAt       DateTime? @map("dedup_started_at")
  /// Set on success only.
  dedupCompletedAt     DateTime? @map("dedup_completed_at")
  dedupError           String?   @map("dedup_error")
  dedupErrorAt         DateTime? @map("dedup_error_at")
  /// Aggregate counts JSON (see comment above).
  dedupCounts          Json?     @map("dedup_counts")
  /// Total existing entities scanned across all 4 entity types.
  dedupCandidatesCount Int?      @map("dedup_candidates_count")
  /// Set when operator confirms duplicate resolution (all needs_review
  /// rows overridden to a final action). Unblocks the commit cohort.
  dedupConfirmedAt     DateTime? @map("dedup_confirmed_at")

  // KAN-913 — Ingestion Cohort 2.7. Commit + audit + Pub/Sub fanout.
  // For each staging row honoring its KAN-911 matchDecision, runCommit
  // either INSERTs a new canonical entity, UPDATEs an existing one, or
  // skips. Each row commit is wrapped in its own prisma.$transaction
  // (canonical write + staging status update + audit log entry are
  // all-or-nothing per row). Pub/Sub fanout fires AFTER the transaction
  // commits (env-flag-gated via IMPORT_EVENTS_ENABLED, KAN-852 pattern).
  // Gated on dedupConfirmedAt IS NOT NULL — preserves the *ConfirmedAt
  // convention established by KAN-907/911.
  //
  // commitStatus state machine:
  //   pending  → running    (runCommit called)
  //   running  → succeeded  (all rows committed, zero in commitErrors)
  //            → partial    (some committed, some in commitErrors)
  //            → failed     (commit aborted entirely; e.g., DB error,
  //                          OR ALL rows ended up in commitErrors)
  //
  // Shape of commitErrors JSON:
  //   [
  //     {
  //       stagingRowId: string,
  //       entityType: 'contact' | 'company' | 'deal' | 'order',
  //       sourceRowIndex: number,
  //       reason: 'contact_not_found' | 'pipeline_not_found'
  //             | 'stage_not_found'   | 'order_number_duplicate'
  //             | 'company_name_required' | 'needs_review_unresolved'
  //             | 'update_target_missing' | 'unknown',
  //       unresolvedKey?: string,    // the email / pipelineName / etc.
  //       errorMessage: string,
  //     },
  //     ...
  //   ]
  commitStatus       ImportCommitStatus @default(pending) @map("commit_status")
  commitStartedAt    DateTime?          @map("commit_started_at")
  /// Set on terminal commitStatus (succeeded | partial | failed).
  commitCompletedAt  DateTime?          @map("commit_completed_at")
  /// Incremented in lockstep with each per-row $transaction success.
  committedRowCount  Int                @default(0) @map("committed_row_count")
  /// Incremented per row that lands in commitErrors.
  failedRowCount     Int                @default(0) @map("failed_row_count")
  /// JSON array of per-row error records (see comment above).
  commitErrors       Json               @default("[]") @map("commit_errors")

  // Error tracking.
  errorMessage String?   @map("error_message")
  errorAt      DateTime? @map("error_at")

  // Timestamps.
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  uploadConfirmedAt     DateTime? @map("upload_confirmed_at")
  inspectionStartedAt   DateTime? @map("inspection_started_at")
  inspectionCompletedAt DateTime? @map("inspection_completed_at")

  // Relations.
  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  createdBy        User                   @relation(fields: [createdByUserId], references: [id])
  // KAN-903 — Ingestion Cohort 2.5 (staging tables). CASCADE on the
  // staging side: deleting an ImportJob drops its staging rows.
  stagingContacts  ImportStagingContact[]
  stagingCompanies ImportStagingCompany[]
  stagingDeals     ImportStagingDeal[]
  stagingOrders    ImportStagingOrder[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([createdByUserId])
  // KAN-904 — filter jobs by detection state for the future cohort
  // dashboard ("show me all unknown classifications for retraining").
  @@index([tenantId, detectedEntityType])
  // KAN-905 — filter jobs by mapping-confirmation state ("show me
  // mapped-but-not-yet-committed imports").
  @@index([tenantId, fieldMappingConfirmedAt])
  // KAN-907 — filter jobs by row-classification-confirmation state
  // ("show me classified-but-not-yet-mapped imports").
  @@index([tenantId, rowClassificationConfirmedAt])
  // KAN-911 — filter jobs by dedup-resolution state ("show me imports
  // ready for commit").
  @@index([tenantId, dedupConfirmedAt])
  // KAN-913 — filter jobs by commit state ("show me running / partial
  // commits that need operator attention").
  @@index([tenantId, commitStatus])
  @@map("import_jobs")
}

// ─────────────────────────────────────────────────────────────────────
// INGESTION STAGING — KAN-903 Cohort 2.5 (staging tables)
//
// PR 3 of 8 in the Cohort 2 ingestion pipeline. Pure schema work.
// The mapping (PR 5), dedup (PR 6), and commit (PR 8) cohorts will
// write + read these tables; this PR just lays them down.
//
// Each staging table mirrors a canonical CRM entity (Contact / Company
// / Deal / Order) with the LEAN MIRROR shape: enough strongly-typed
// columns for the review UI to display rows + dedup heuristics to key
// on, plus a `sourceRowData Json` blob carrying the full original CSV /
// XLSX row. PR 8 commit projects from `sourceRowData` to the canonical
// entity — staging is NOT required to be shape-identical to the target.
//
// Lifecycle (StagingStatus enum):
//   pending → mapping_error          (PR 5 mapping failed)
//           → dedup_error            (PR 6 dedup failed)
//           → ready → committed      (PR 8 wrote canonical row)
//                   → skipped        (user chose skip during dedup)
//
// Resolution strategy: pipelineName / stageName / contactEmail are
// stored as raw strings on staging Deal + Order rows. Resolution to
// canonical pipelineId / currentStageId / contactId happens at commit
// time (PR 8). NOT FK constraints — staging rows can land before the
// canonical entity exists.
// ─────────────────────────────────────────────────────────────────────

enum StagingStatus {
  pending
  mapping_error
  dedup_error
  ready
  committed
  skipped

  @@map("staging_status")
}

model ImportStagingContact {
  id              String        @id @default(cuid())
  importJobId     String        @map("import_job_id")
  tenantId        String        @map("tenant_id")
  sourceRowIndex  Int           @map("source_row_index")
  /// Full-fidelity raw row from the parsed CSV / XLSX. Commit cohort
  /// projects from here to the canonical Contact at write time.
  sourceRowData   Json          @map("source_row_data")
  stagingStatus   StagingStatus @default(pending) @map("staging_status")
  /// Populated by Cohort 2.6 dedup with match candidates + chosen action.
  matchDecision   Json?         @map("match_decision")
  mappingError    String?       @map("mapping_error")
  dedupError      String?       @map("dedup_error")
  /// Nullable — populated at commit when canonical row exists. Not a FK
  /// (resolution can lag; canonical row may not yet exist at staging time).
  targetContactId String?       @map("target_contact_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Mirror columns — review UI display + dedup keys only.
  email          String?
  phone          String?
  firstName      String?         @map("first_name")
  lastName       String?         @map("last_name")
  companyName    String?         @map("company_name")
  lifecycleStage LifecycleStage? @map("lifecycle_stage")
  source         ContactSource?

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([importJobId, sourceRowIndex])
  @@index([importJobId, stagingStatus])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([targetContactId])
  @@map("import_staging_contacts")
}

model ImportStagingCompany {
  id              String        @id @default(cuid())
  importJobId     String        @map("import_job_id")
  tenantId        String        @map("tenant_id")
  sourceRowIndex  Int           @map("source_row_index")
  sourceRowData   Json          @map("source_row_data")
  stagingStatus   StagingStatus @default(pending) @map("staging_status")
  matchDecision   Json?         @map("match_decision")
  mappingError    String?       @map("mapping_error")
  dedupError      String?       @map("dedup_error")
  targetCompanyId String?       @map("target_company_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Mirror columns — review UI display + dedup keys only.
  name           String?
  domain         String?
  industry       String?
  billingCity    String? @map("billing_city")
  billingCountry String? @map("billing_country")

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([importJobId, sourceRowIndex])
  @@index([importJobId, stagingStatus])
  @@index([tenantId, domain])
  @@index([tenantId, name])
  @@index([targetCompanyId])
  @@map("import_staging_companies")
}

model ImportStagingDeal {
  id             String        @id @default(cuid())
  importJobId    String        @map("import_job_id")
  tenantId       String        @map("tenant_id")
  sourceRowIndex Int           @map("source_row_index")
  sourceRowData  Json          @map("source_row_data")
  stagingStatus  StagingStatus @default(pending) @map("staging_status")
  matchDecision  Json?         @map("match_decision")
  mappingError   String?       @map("mapping_error")
  dedupError     String?       @map("dedup_error")
  targetDealId   String?       @map("target_deal_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Mirror columns — review UI display + dedup keys only.
  name              String?
  value             Decimal?    @db.Decimal(12, 2)
  currency          String?     @db.VarChar(3)
  status            DealStatus?
  expectedCloseDate DateTime?   @map("expected_close_date") @db.Date
  /// Raw — resolved to Contact.id at commit-time. NOT a FK.
  contactEmail      String?     @map("contact_email")
  /// Raw — resolved to Company.id at commit-time. NOT a FK.
  companyName       String?     @map("company_name")
  /// Raw — resolved to Pipeline.id at commit-time. NOT a FK.
  pipelineName      String?     @map("pipeline_name")
  /// Raw — resolved to Stage.id at commit-time. NOT a FK.
  stageName         String?     @map("stage_name")

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([importJobId, sourceRowIndex])
  @@index([importJobId, stagingStatus])
  @@index([tenantId, contactEmail])
  @@index([tenantId, name])
  @@index([targetDealId])
  @@map("import_staging_deals")
}

model ImportStagingOrder {
  id             String        @id @default(cuid())
  importJobId    String        @map("import_job_id")
  tenantId       String        @map("tenant_id")
  sourceRowIndex Int           @map("source_row_index")
  sourceRowData  Json          @map("source_row_data")
  stagingStatus  StagingStatus @default(pending) @map("staging_status")
  matchDecision  Json?         @map("match_decision")
  mappingError   String?       @map("mapping_error")
  dedupError     String?       @map("dedup_error")
  targetOrderId  String?       @map("target_order_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Mirror columns — review UI display + dedup keys only.
  orderNumber     String?      @map("order_number")
  providerOrderId String?      @map("provider_order_id")
  status          OrderStatus?
  grandTotal      Decimal?     @map("grand_total") @db.Decimal(12, 2)
  currency        String?      @db.VarChar(3)
  placedAt        DateTime?    @map("placed_at")
  /// Raw — resolved to Contact.id at commit-time. NOT a FK.
  contactEmail    String?      @map("contact_email")
  /// Raw — resolved to Company.id at commit-time. NOT a FK.
  companyName     String?      @map("company_name")

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([importJobId, sourceRowIndex])
  @@index([importJobId, stagingStatus])
  @@index([tenantId, orderNumber])
  @@index([tenantId, providerOrderId])
  @@index([targetOrderId])
  @@map("import_staging_orders")
}
