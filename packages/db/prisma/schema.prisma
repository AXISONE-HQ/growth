// ─────────────────────────────────────────────
// KAN-826 — Knowledge Layer schema (Sprint 11a)
// ─────────────────────────────────────────────
//
// REPLACES KAN-706 legacy (KnowledgeSource/KnowledgeChunk/KnowledgeIngestion +
// KnowledgeSourceType/Status enums). All legacy tables were 0-row at the
// time of KAN-826 cutover (KAN-786 a+b shipped, sub-cohort c reverted in
// KAN-791 first commit; tables never populated).
//
// Four new models per Sprint 11a Architect Spec §2:
//   - KnowledgeSource: provenance + lifecycle (string-typed sourceType
//     + status, simpler than KAN-706 enum approach)
//   - KnowledgeChunk:  chunked content + pgvector embedding(1536) +
//     denormalized tenantId + category for retrieval-perf partial index
//   - KnowledgeGapSummary: aggregated query gaps for tenant Knowledge
//     dashboard signal (KAN-830)
//   - ChunkEffectiveness: post-decision outcome lookups (KAN-830 audit)
//
// Embedding column declared as `Unsupported("vector(1536)")` so Prisma
// generates the column natively. HNSW index + partial retrieval index
// added via hand-edited raw SQL in the migration since Prisma cannot
// emit those.
//
// Tenant-isolation: KnowledgeChunk.tenantId is DENORMALIZED (sibling to
// the row's KnowledgeSource.tenantId) for retrieval-perf — drives the
// partial index `WHERE tenant_id, status='ready'` per spec §1.6 hot-path
// query. Prisma middleware in §6.1 enforces tenant filter on all reads.
//
// KnowledgeFilter (KAN-705 routing) and KnowledgeBase (Sprint 5) are
// SEPARATE concerns — preserved unchanged.

model KnowledgeSource {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  /// 'pdf' | 'paste_text' | 'faq' (string per spec §2; not a Prisma enum).
  sourceType    String    @map("source_type")
  /// 'faq' | 'inventory' | 'warranty' | 'pricing' | 'other'. Denormalized
  /// onto chunks for retrieval pre-filter.
  category      String
  title         String?
  /// 'queued' | 'embedding' | 'ready' | 'error' | 'deleted'. Default 'queued'
  /// at insert; transitions through embedding → ready as ingestion runs.
  status        String    @default("queued")
  fileName      String?   @map("file_name")
  fileSizeBytes Int?      @map("file_size_bytes")
  /// SHA-256 hex; per-tenant idempotency key (same file from two tenants stays distinct).
  fileChecksum  String?   @map("file_checksum")
  /// Raw original content (paste_text / faq Q&A body). Null for PDFs (rendered to chunks only).
  rawContent    String?   @map("raw_content") @db.Text
  metadata      Json      @default("{}")
  errorDetail   String?   @map("error_detail")
  /// Set by soft-delete. Hourly cron hard-deletes after 30 days per spec §1.4.
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([fileChecksum])
  @@map("knowledge_source")
}

// KAN-XXX (Services first-class) — KnowledgeChunk parent FK is polymorphic
// across THREE parent tables now: KnowledgeSource, FaqEntry, Service.
// EXACTLY ONE of (sourceId, faqEntryId, serviceId) is set per row. Enforced
// at the DB layer via a 3-way CHECK constraint:
//   CHECK ((source_id IS NOT NULL)::int +
//          (faq_entry_id IS NOT NULL)::int +
//          (service_id IS NOT NULL)::int = 1)
// The 2-way XOR (introduced in KAN-849) is dropped + replaced atomically by
// the migration in this cohort. Belt-and-suspenders: app-layer writers
// (faq-entries.ts, services.ts, knowledge-ingestion-service.ts) only ever
// populate exactly one of the three FKs.
model KnowledgeChunk {
  id           String                      @id @default(uuid())
  /// DENORMALIZED from parent for retrieval performance. Drives
  /// the partial index (tenant_id, category) WHERE status='ready' which
  /// is the hot-path pre-filter on every Brain/Shaper retrieval call.
  tenantId     String                      @map("tenant_id")
  /// Parent FK: KnowledgeSource path (PDF / paste_text). Mutually exclusive
  /// with faqEntryId + serviceId per the 3-way DB CHECK constraint.
  sourceId     String?                     @map("source_id")
  /// Parent FK: FaqEntry path (KAN-849). Mutually exclusive per the CHECK.
  faqEntryId   String?                     @map("faq_entry_id")
  /// KAN-XXX — Parent FK: Service path. Mutually exclusive per the CHECK.
  serviceId    String?                     @map("service_id")
  /// Plain-text chunk content fed to retrieval ranking + LLM context.
  chunkText    String                      @map("chunk_text") @db.Text
  /// 0-based ordinal within the parent. Used for "X of N" UI + ordering.
  position     Int
  /// DENORMALIZED from parent for the partial-index pre-filter. Sentinel
  /// values: 'faq' for FaqEntry chunks, 'service' for Service chunks,
  /// the source's category string for KnowledgeSource chunks.
  category     String
  /// 'ready' | 'deleted'. Soft-delete pattern: chunks marked 'deleted'
  /// disappear from retrieval but remain for audit trail until 30-day cron.
  status       String                      @default("ready")
  /// For Q&A chunks only: the question text (chunkText holds the answer).
  /// Null for PDFs / paste_text / service chunks.
  questionText String?                     @map("question_text") @db.Text
  /// pgvector(1536) — matches OpenAI text-embedding-3-small. Hardcoded
  /// dimension forces deliberation if the model ever changes.
  embedding    Unsupported("vector(1536)")
  metadata     Json                        @default("{}")
  createdAt    DateTime                    @default(now()) @map("created_at")

  source   KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  faqEntry FaqEntry?        @relation(fields: [faqEntryId], references: [id], onDelete: Cascade)
  service  Service?         @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([faqEntryId])
  @@index([serviceId])
  @@index([tenantId, status, category])
  @@map("knowledge_chunk")
}

// ─────────────────────────────────────────────
// KAN-XXX — FAQ as first-class entity (Sprint 11b)
// ─────────────────────────────────────────────
//
// Supersedes KAN-841's FAQ-via-KnowledgeSource multi-pair contract. Each
// FAQ entry is one row with one Q+A pair → one KnowledgeChunk via the
// faqEntryId FK. Embedding generated SYNCHRONOUSLY on create/update from
// `Question: <q>\n\nAnswer: <a>` via the existing text-embedding-3-small
// pipeline (no Pub/Sub; the embedder is a pure function).
//
// Tier-gating intentionally omitted — all tiers (free, starter, pro,
// enterprise) get unlimited FAQ entries per the locked decisions in this
// cohort's brief.
//
// Status transitions (sync, in-process):
//   queued → embedding → ready  (success path)
//   queued → embedding → error  (terminal failure with errorDetail)
model FaqEntry {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  question    String    @db.Text
  answer      String    @db.Text
  /// 'queued' | 'embedding' | 'ready' | 'error'. Soft-delete via deletedAt;
  /// status remains its terminal value when deletedAt is set so admin lists
  /// can exclude deleted rows via `WHERE deleted_at IS NULL`.
  status      String    @default("queued")
  errorDetail String?   @map("error_detail")
  /// Set by soft-delete. Hourly cron hard-deletes after 30 days, mirroring
  /// the KnowledgeSource pattern (architect spec §1.4).
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
  @@map("faq_entries")
}

// ─────────────────────────────────────────────
// KAN-XXX — Services as first-class entity (Sprint 11b)
// ─────────────────────────────────────────────
//
// Structured service catalog: title + description + pricing (numeric +
// unit OR custom-label escape hatch) + availability window (optional) +
// included/excluded line items. Each row produces exactly one
// KnowledgeChunk via the polymorphic `serviceId` FK; the embedder runs
// SYNCHRONOUSLY on create/update from a templated text body (see
// `packages/api/src/services/services.ts:buildServiceEmbedText`).
//
// Tier-gating intentionally omitted — all tiers get unlimited services
// per the locked decisions in this cohort's brief (mirrors FAQ pattern).
//
// Status transitions (sync, in-process):
//   queued → embedding → ready  (success path)
//   queued → embedding → error  (terminal failure with errorDetail)
model Service {
  id               String           @id @default(uuid())
  tenantId         String           @map("tenant_id")
  title            String
  description      String           @db.Text
  /// Nullable when priceUnit=CUSTOM (operator typed a free-form label
  /// like "Contact for quote" instead of a numeric price). Otherwise the
  /// numeric value paired with the priceUnit (e.g., 50.00 + PER_HOUR =
  /// "$50 per hour").
  price            Decimal?         @db.Decimal(10, 2)
  priceUnit        ServicePriceUnit @map("price_unit")
  /// Required when priceUnit=CUSTOM; otherwise null. App layer validates;
  /// no DB CHECK because Prisma can't natively express "required iff X".
  priceCustomLabel String?          @map("price_custom_label")
  /// Availability window. Both nullable; null+null = "Ongoing" rendering.
  /// Stored as Date (no time component) per Decision F.
  startDate        DateTime?        @map("start_date") @db.Date
  endDate          DateTime?        @map("end_date") @db.Date
  /// Bullet-point arrays. Postgres native text[] via Prisma String[].
  /// Empty arrays = "skip the section" in the rendered embed text.
  includedItems    String[]         @map("included_items")
  excludedItems    String[]         @map("excluded_items")
  /// 'queued' | 'embedding' | 'ready' | 'error'. Mirrors FaqEntry pattern.
  status           String           @default("queued")
  errorDetail      String?          @map("error_detail")
  /// Set by soft-delete. Hourly cron hard-deletes after 30 days.
  deletedAt        DateTime?        @map("deleted_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
  @@map("services")
}

/// Pricing unit for a Service. CUSTOM is the escape hatch for non-numeric
/// pricing ("Contact for quote", "By the engagement", etc.) — paired with
/// `priceCustomLabel` when chosen.
enum ServicePriceUnit {
  PER_HOUR
  PER_MONTH
  PER_PROJECT
  PER_UNIT
  FIXED
  CUSTOM

  @@map("service_price_unit")
}

model KnowledgeGapSummary {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  /// Normalized form of the customer query that failed retrieval (e.g.,
  /// trimmed + lowercased). Used as dedup key per tenant. KAN-830 cron
  /// aggregates `knowledge.gap_detected` events into rows on this table.
  normalizedQuery String   @map("normalized_query") @db.VarChar(500)
  countLast7d     Int      @default(0) @map("count_last_7d")
  countLast30d    Int      @default(0) @map("count_last_30d")
  lastSeen        DateTime @map("last_seen")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, normalizedQuery])
  @@index([tenantId, countLast7d])
  @@map("knowledge_gap_summary")
}

model ChunkEffectiveness {
  id            String    @id @default(uuid())
  /// References KnowledgeChunk.id. NOT a foreign-key constraint here so a
  /// chunk soft-delete doesn't cascade away historical effectiveness rows;
  /// reads filter to live chunks via JOIN to KnowledgeChunk.
  chunkId       String    @map("chunk_id")
  /// References Decision.id. Loose-FK semantics (no constraint).
  decisionId    String    @map("decision_id")
  /// 'replied_positive' | 'replied_negative' | 'no_reply' | 'other'.
  outcomeStatus String    @map("outcome_status")
  outcomeAt     DateTime? @map("outcome_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([chunkId])
  @@index([decisionId])
  @@map("chunk_effectiveness")
}

// ─────────────────────────────────────────────
// KAN-745 PR B — LLM cost observability rollups
// ─────────────────────────────────────────────
//
// In-process apps/api Pub/Sub subscriber consumes llm.call events from the
// llm.call topic (KAN-699 emit + KAN-745 PR A augments) and UPSERTs into
// this table on a per-(tenant, hourBucket, callerTagPrefix, pricingVersion)
// key. Concurrent-safe: two subscriber instances flushing the same hour
// bucket race on the unique key — Prisma's upsert handles the conflict.
//
// pricingVersion is part of the unique key so a quarterly MODEL_PRICING bump
// (per `feedback_model_pricing_refresh_discipline`) doesn't conflict with
// existing rollups. UI/router queries SUM across pricing versions for
// display — pricingVersion is audit trail, not a user-facing dimension.

model LlmCostRollup {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  hourBucket        DateTime @map("hour_bucket")
  callerTagPrefix   String   @map("caller_tag_prefix")
  callCount         Int      @default(0) @map("call_count")
  totalInputTokens  Int      @default(0) @map("total_input_tokens")
  totalOutputTokens Int      @default(0) @map("total_output_tokens")
  totalCostUsd      Float    @default(0) @map("total_cost_usd")
  pricingVersion    String   @map("pricing_version")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, hourBucket, callerTagPrefix, pricingVersion])
  @@index([tenantId])
  @@index([tenantId, hourBucket])
  @@map("llm_cost_rollups")
}

// ─────────────────────────────────────────────
// PHASE 1 PIVOT (KAN-791) — Deal-as-Lifecycle
// See docs/prds/phase-1-deal-engagement.md §3 (pivot 2026-05-03)
// Sub-cohort (a) shipped Deal+Engagement base tables; KAN-791 EXTENDS:
//   - Deal: add pipelineId/currentStageId/enteredStageAt/microObjectiveProgress;
//           value → Decimal default 0; drop status/closedAt
//   - Engagement: dealId becomes REQUIRED FK
//   - Stage: outcomeType + followUpCadence (see model above; relations updated)
//   - DealStageHistory: NEW (replaces lead_stage_history)
//   - StageOutcomeType: NEW enum
// Pre-flight #4 verified microObjectiveProgress = 0 prod contacts (2026-05-03);
// Contact.microObjectiveProgress drop is safe (no backfill needed).
// ─────────────────────────────────────────────

/// Phase 1 (KAN-791) — Deal as the lifecycle entity
/// KAN-879 — CRM Core Schema extensions (status / name / closedAt / lost reason /
/// products / ownership / Company relation / extension columns).
model Deal {
  id                     String          @id @default(cuid())
  tenantId               String          @map("tenant_id")
  contactId              String          @map("contact_id")
  correlationId          String?         @unique @map("correlation_id")
  // KAN-791 — pipeline + stage state (moved from Contact)
  pipelineId             String          @map("pipeline_id")
  currentStageId         String          @map("current_stage_id")
  enteredStageAt         DateTime        @default(now()) @map("entered_stage_at")
  // KAN-791 — per-Deal MO progress (moved from Contact.microObjectiveProgress;
  // pre-flight #4 verified 0 prod contacts had non-default values, no backfill)
  microObjectiveProgress Json            @default("{}") @map("micro_objective_progress")
  // KAN-791 — value defaults to 0 (was Decimal?). KAN-790 deferred enrichment.
  value                  Decimal         @default(0) @db.Decimal(12, 2)
  currency               String          @default("USD") @db.VarChar(3)
  metadata               Json            @default("{}")
  // KAN-879 — CRM Core Schema additions
  name                   String          @default("Untitled deal")
  /// Derived from currentStage.outcomeType via migration backfill; future
  /// transitions should keep this in sync (next cohort wires the engine).
  status                 DealStatus      @default(open)
  /// 0-100 (kept loose as Int; no constraint here — UI / API validate).
  probability            Int?
  expectedCloseDate      DateTime?       @map("expected_close_date") @db.Date
  /// Set when status transitions to won/lost. Migration backfills from
  /// DealStageHistory terminal transitions.
  closedAt               DateTime?       @map("closed_at")
  lostReason             DealLostReason? @map("lost_reason")
  lostReasonDetail       String?         @map("lost_reason_detail")
  wonProductSummary      String?         @map("won_product_summary")
  /// Line-item shape determined by next cohort; opaque Json today.
  products               Json            @default("[]")
  ownerId                String?         @map("owner_id")
  assignedAgentId        String?         @map("assigned_agent_id")
  companyId              String?         @map("company_id")
  externalIds            Json            @default("{}") @map("external_ids")
  customFields           Json            @default("{}") @map("custom_fields")
  aiContext              Json            @default("{}") @map("ai_context")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipeline      Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  currentStage  Stage              @relation("DealCurrentStage", fields: [currentStageId], references: [id], onDelete: Restrict)
  engagements   Engagement[]
  stageHistory  DealStageHistory[]
  deferredSends DeferredSend[]
  // KAN-879
  company       Company?           @relation(fields: [companyId], references: [id])
  orders        Order[]

  @@index([tenantId, currentStageId])
  @@index([tenantId, pipelineId])
  @@index([tenantId, contactId])
  @@index([tenantId, status])
  @@index([tenantId, companyId, status])
  @@index([tenantId, expectedCloseDate])
  @@map("deals")
}

/// KAN-814 — Deferred outbound queue.
///
/// When Send Policy returns `defer` (e.g., outside tenant send window) the
/// dispatcher persists the would-be send here instead of the previous
/// log+drop behavior. A 5-min cron worker (Cloud Scheduler → growth-api
/// `/internal/cron/deferred-send-evaluator`) re-evaluates Send Policy on
/// pending rows whose `defer_until` has elapsed. On `allow` → dispatch +
/// mark `dispatched`. On still-defer → increment attempts + push
/// `defer_until` forward. After 12 attempts (~24h) → `expired`.
///
/// **Supersession invariant**: a fresh inbound on the same (deal_id,
/// contact_id) marks pending rows `cancelled` with
/// `cancelReason='superseded_by_fresh_inbound'` BEFORE Brain re-evaluates,
/// so a stale defer doesn't double-send after the new inbound's outbound
/// already fires.
model DeferredSend {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  dealId        String    @map("deal_id")
  contactId     String    @map("contact_id")
  /// Full payload to re-dispatch — brainDecision blob + composedMessage +
  /// connectionId + replyTo + tone/token metadata. Captured at defer-time
  /// to honor Brain's T1 intent (don't re-shape on re-dispatch — see
  /// feedback note in deferred-send-evaluator.ts).
  payload       Json
  deferUntil    DateTime  @map("defer_until")
  deferReason   String    @map("defer_reason")
  /// pending | dispatched | expired | cancelled
  status        String    @default("pending")
  attempts      Int       @default(0)
  lastAttemptAt DateTime? @map("last_attempt_at")
  /// Set when status='cancelled'. Known values:
  ///   - 'superseded_by_fresh_inbound' (KAN-814 supersession path)
  ///   - 'policy_now_denies' (Send Policy returned deny on re-eval)
  cancelReason  String?   @map("cancel_reason")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Cron worker scan: pending rows whose defer_until has elapsed
  @@index([status, deferUntil])
  // Supersession lookup: pending rows for a (tenant, deal, contact) tuple
  @@index([tenantId, dealId, contactId, status])
  // Tenant-bounded recency queries (audit dashboards, expired-row cleanup)
  @@index([tenantId, createdAt])
  @@map("deferred_sends")
}

/// KAN-791 — DealStageHistory replaces lead_stage_history (deal-scoped, not contact-scoped)
model DealStageHistory {
  id             String   @id @default(cuid())
  dealId         String   @map("deal_id")
  fromStageId    String?  @map("from_stage_id")
  toStageId      String   @map("to_stage_id")
  transitionedAt DateTime @default(now()) @map("transitioned_at")
  /// Semantic descriptor — bounded set: 'normalizer' | 'agent' | 'human' | 'system' | 'rule'
  triggeredBy    String   @map("triggered_by")
  /// Typed FK — populated only when transition came from a Decision firing.
  /// Phase 2 KAN-796 (AI Stages Evolution Logic) emits these at scale.
  decisionId     String?  @map("decision_id")
  metadata       Json     @default("{}")

  deal      Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage Stage?    @relation("DealStageFromHistory", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStage   Stage     @relation("DealStageToHistory", fields: [toStageId], references: [id], onDelete: Restrict)
  decision  Decision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  @@index([dealId, transitionedAt])
  @@index([toStageId])
  @@index([decisionId])
  @@map("deal_stage_history")
}

enum StageOutcomeType {
  open
  terminal_won
  terminal_lost

  @@map("stage_outcome_type")
}

/// Phase 1 (KAN-791) — Engagement attached to Deal (dealId REQUIRED).
/// contactId stays as denormalized fast-query field.
model Engagement {
  id             String      @id @default(cuid())
  tenantId       String      @map("tenant_id")
  // KAN-791 — dealId REQUIRED (was implicit/missing). Engagement attaches to Deal;
  // queryable to Contact via the FK chain.
  dealId         String      @map("deal_id")
  contactId      String      @map("contact_id")
  correlationId  String?     @unique @map("correlation_id")
