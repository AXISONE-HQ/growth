# Copy to apps/connectors/.env for local dev.
# Production values live in GCP Secret Manager — never commit real secrets.

NODE_ENV=development
PORT=8081
LOG_LEVEL=debug

# GCP
GCP_PROJECT_ID=growth-dev-12345
# Uncomment for local Pub/Sub emulator:
# PUBSUB_EMULATOR_HOST=localhost:8085

# Shared database with @growth-ai/api
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/growth

# Redis for rate limiting + webhook idempotency
REDIS_URL=redis://localhost:6379

# Internal tRPC auth (32+ char random string)
INTERNAL_TRPC_AUTH_TOKEN=change-me-to-a-long-random-string-for-dev-only

# Public URL provider webhooks callback to (Cloud Run service URL in prod).
# For local dev, use an ngrok/cloudflared tunnel or leave blank.
# PUBLIC_WEBHOOK_BASE_URL=https://connectors.growth.axisone.com

# Feature flags — enable each channel only after the adapter lands
ENABLE_TWILIO=false
ENABLE_SENDGRID=false
ENABLE_META=false
