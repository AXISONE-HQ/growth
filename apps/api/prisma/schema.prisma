// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum PlanTier {
  free
  starter
  growth
  enterprise
}

enum AgentType {
  communication
  revenue
  operational
  escalation
}

enum ActionStatus {
  queued
  sent
  delivered
  opened
  failed
}

enum OutcomeResult {
  completed
  failed
  expired
}

enum EscalationPriority {
  critical
  high
  medium
  low
}

enum EscalationStatus {
  open
  claimed
  resolved
  dismissed
}

enum PipelineType {
  sales
  reengagement
  upsell
  custom
}

enum SenderType {
  ai
  contact
  human
}

enum LifecycleStage {
  prospect
  lead
  customer
  retained
  churned
}

enum ConversationStatus {
  active
  paused
  closed
}

// Models
model Tenant {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  planTier             PlanTier @default(free)
  blueprintId          String?  @db.Uuid
  aiPermissions        Json     @default("{}")
  confidenceThreshold  Int      @default(70)
  domain               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  blueprint            Blueprint? @relation(fields: [blueprintId], references: [id])
  brainSnapshots       BrainSnapshot[]
  contacts             Contact[]
  objectives           Objective[]
  pipelines            Pipeline[]
  decisions            Decision[]
  outcomes             Outcome[]
  auditLogs            AuditLog[]
  strategyWeights      StrategyWeights[]
  escalations          Escalation[]
  conversations        Conversation[]
  companyInfo          CompanyInfo?
  products             Product[]
  policyRules          PolicyRule[]
  faqs                 FAQ[]
  knowledgeDocuments   KnowledgeDocument[]
  competitors          Competitor[]
  salesObjections      SalesObjection[]
  // Settings module relations
  channels             CommunicationChannel[]
  integrations         Integration[]
  teamMembers          TeamMember[]
  invitations          Invitation[]
  notificationPrefs    NotificationPreference[]
  securitySetting      SecuritySetting?

  @@index([blueprintId])
  @@index([createdAt])
}

model Blueprint {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vertical           String
  name               String
  customerModel      Json     @default("{}")
  jochurys           Json     @default("{}")
  strategyTemplates  Json     @default("{}")
  createdAt          DateTime @default(now())

  // Relations
  tenants            Tenant[]

  @@unique([vertical, name])
  @@index([createdAt])
}

model BrainSnapshot {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @db.Uuid
  companyTruth     Json     @default("{}")
  behavioralModel  Json     @default("{}")
  outcomeModel     Json     @default("{}")
  version          Int      @default(1)
  createdAt        DateTime @default(now())

  // Relations
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([version])
  @@index([createdAt])
}

model Contact {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @db.Uuid
  email            String
  phone            String?
  firstName        String?
  lastName         String?
  company          String?
  externalIds      Json     @default("{}")
  dataQualityScore Int      @default(0)
  segment          String?
  lifecycleStage   LifecycleStage?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactStates    ContactState[]
  decisions        Decision[]
  outcomes         Outcome[]
  auditLogs        AuditLog[]
  escalations      Escalation[]
  conversations    Conversation[]
  messages         Message[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([lifecycleStage])
  @@index([createdAt])
}

model ContactState {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId       String   @db.Uuid
  objectiveId     String   @db.Uuid
  subObjectives   Json     @default("[]")
  strategyCurrent String?
  confidenceScore Int      @default(0)
  updatedAt       DateTime @updatedAt

  // Relations
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  objective       Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@unique([contactId, objectiveId])
  @@index([contactId])
  @@index([objectiveId])
}

model Objective {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @db.Uuid
  type             String
  name             String
  successCondition Json     @default("{}")
  subObjectives    Json     @default("[]")
  blueprintId      String?  @db.Uuid
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  // Relations
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactStates    ContactState[]
  outcomes         Outcome[]
  decisions        Decision[]

  @@index([tenantId])
  @@index([active])
  @@index([createdAt])
}

model Pipeline {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  name            String
  type            PipelineType
  stages          Json     @default("[]")
  objectives      Json     @default("[]")
  audienceFilters Json     @default("{}")
  aiSettings      Json     @default("{}")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([active])
  @@index([createdAt])
}

model Decision {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId       String   @db.Uuid
  tenantId        String   @db.Uuid
  objectiveId     String?  @db.Uuid
  strategySelected String
  actionType      String
  confidence      Int      @default(0)
  reasoning       String?
  createdAt       DateTime @default(now())

  // Relations
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  objective       Objective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  actions         Action[]
  escalations     Escalation[]

  @@index([tenantId])
  @@index([contactId])
  @@index([objectiveId])
  @@index([createdAt])
}

model Action {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  decisionId      String   @db.Uuid
  agentType       AgentType
  channel         String
  payload         Json     @default("{}")
  status          ActionStatus @default(queued)
  sentAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())

  // Relations
  decision        Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([status])
  @@index([createdAt])
}

model Outcome {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId       String   @db.Uuid
  objectiveId     String   @db.Uuid
  tenantId        String   @db.Uuid
  result          OutcomeResult
  reasonCategory  String?
  recordedAt      DateTime @default(now())

  // Relations
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  objective       Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([contactId, objectiveId])
  @@index([tenantId])
  @@index([contactId])
  @@index([objectiveId])
  @@index([result])
  @@index([recordedAt])
}

model AuditLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  actor           String
  actionType      String
  contactId       String?  @db.Uuid
  payload         Json     @default("{}")
  reasoning       String?
  autoApproved    Boolean  @default(false)
  createdAt       DateTime @default(now())

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([contactId])
  @@index([actionType])
  @@index([createdAt])
}

model StrategyWeights {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  strategyType    String
  segment         String
  winRate         Float    @default(0)
  sampleSize      Int      @default(0)
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, strategyType, segment])
  @@index([tenantId])
  @@index([updatedAt])
}

model Escalation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  contactId       String   @db.Uuid
  decisionId      String?  @db.Uuid
  reason          String
  priority        EscalationPriority @default(medium)
  status          EscalationStatus @default(open)
  assignedTo      String?
  summary         String?
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  decision        Decision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([contactId])
  @@index([decisionId])
  @@index([priority])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  contactId       String   @db.Uuid
  channel         String
  status          ConversationStatus @default(active)
  aiHandled       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@index([tenantId])
  @@index([contactId])
  @@index([status])
  @@index([createdAt])
}

model Message {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId  String   @db.Uuid
  senderId        String?  @db.Uuid
  senderType      SenderType
  content         String
  channel         String
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  // Relations
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact         Contact? @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([senderId])
  @@index([senderType])
  @@index([createdAt])
}

// ============================================================================
// KNOWLEDGE CENTER MODELS
// ============================================================================

enum PolicyCategory {
  warranty
  financing
  rule
}

model CompanyInfo {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @unique @db.Uuid
  vision          String   @default("")
  mission         String   @default("")
  websiteUrl      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Product {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  name            String
  category        String?
  price           String?
  description     String?
  sku             String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([category])
  @@index([active])
  @@index([createdAt])
}

model PolicyRule {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String          @db.Uuid
  category        PolicyCategory
  title           String
  content         String
  sortOrder       Int             @default(0)
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([category])
  @@index([active])
  @@index([sortOrder])
  @@index([createdAt])
}

model FAQ {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  question        String
  answer          String
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([active])
  @@index([sortOrder])
  @@index([createdAt])
}

model KnowledgeDocument {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  name            String
  type            String
  sizeBytes       Int      @default(0)
  gcsPath         String?
  uploadedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================================
// COMPETITOR INTELLIGENCE MODELS
// ============================================================================

enum CompetitorStatus {
  active
  inactive
  archived
}

enum NewsSentiment {
  positive
  negative
  neutral
}

model Competitor {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String           @db.Uuid
  name            String
  website         String
  description     String?
  logoUrl         String?
  employeeCount   Int?
  customerCount   Int?
  annualRevenue   String?
  segment         String?
  status          CompetitorStatus @default(active)
  metadata        Json             @default("{}")
  lastAnalyzedAt  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  battleCards     CompetitorBattleCard[]
  news            CompetitorNews[]

  @@unique([tenantId, website])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

model CompetitorBattleCard {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  competitorId    String   @db.Uuid
  overview        String
  strengths       Json     @default("[]")
  weaknesses      Json     @default("[]")
  differentiators Json     @default("[]")
  objections      Json     @default("[]")
  talkingPoints   Json     @default("[]")
  version         Int      @default(1)
  generatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([version])
  @@index([createdAt])
}

model CompetitorNews {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  competitorId    String        @db.Uuid
  title           String
  summary         String
  sourceUrl       String?
  publishedAt     DateTime?
  sentiment       NewsSentiment @default(neutral)
  relevanceScore  Float         @default(0)
  createdAt       DateTime      @default(now())

  // Relations
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([sentiment])
  @@index([publishedAt])
  @@index([createdAt])
}

// ============================================================================
// SALES OBJECTIONS MODELS
// ============================================================================

enum ObjectionCategory {
  pricing
  competition
  trust
  timing
  product
  authority
  need
  other
}

enum ObjectionTrend {
  hot
  rising
  stable
  declining
}

enum ObjectionResponseStatus {
  auto_generated
  edited
  approved
  archived
}

model SalesObjection {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String             @db.Uuid
  objectionText   String
  category        ObjectionCategory  @default(other)
  trend           ObjectionTrend     @default(stable)
  mentionCount    Int                @default(0)
  winRate         Float              @default(0)
  lastMentionedAt DateTime?
  active          Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Relations
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responses       ObjectionResponse[]

  @@index([tenantId])
  @@index([category])
  @@index([trend])
  @@index([active])
  @@index([mentionCount])
  @@index([createdAt])
}

model ObjectionResponse {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  objectionId         String                   @db.Uuid
  fieldName           String                   // "recommendedResponse", "talkTrack", "keyDifferentiators"
  content             String
  originalContent     String?                  // Stores original AI-generated content before edits
  status              ObjectionResponseStatus  @default(auto_generated)
  editedBy            String?                  // User who last edited
  editedAt            DateTime?
  llmModel            String?                  // Which model generated it (e.g. "claude-3.5-sonnet")
  llmPromptVersion    String?                  // Prompt version for reproducibility
  version             Int                      @default(1)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  // Relations
  objection           SalesObjection           @relation(fields: [objectionId], references: [id], onDelete: Cascade)
  editHistory         ObjectionEditHistory[]

  @@unique([objectionId, fieldName, version])
  @@index([objectionId])
  @@index([fieldName])
  @@index([status])
  @@index([createdAt])
}

model ObjectionEditHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  responseId      String   @db.Uuid
  previousContent String
  newContent      String
  editedBy        String
  editedAt        DateTime @default(now())

  // Relations
  response        ObjectionResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@index([editedAt])
}


// ============================================================================
// SETTINGS MODULE — Enums
// ============================================================================

enum ChannelType {
  email
  sms
  whatsapp
}

enum ChannelStatus {
  connected
  disconnected
  error
}

enum IntegrationCategory {
  crm
  payments
  calendar
  commerce
  other
}

enum IntegrationStatus {
  connected
  disconnected
  syncing
  error
}

enum TeamRole {
  owner
  admin
  agent
  viewer
}

enum InvitationStatus {
  pending
  accepted
  expired
  cancelled
}

enum NotificationType {
  escalation
  daily_digest
  weekly_report
  brain_update
}

// ============================================================================
// SETTINGS MODULE — Models
// ============================================================================

model CommunicationChannel {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String        @db.Uuid
  type       ChannelType
  provider   String
  config     Json          @default("{}")
  status     ChannelStatus @default(disconnected)
  lastTestedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
  @@index([status])
}

model Integration {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String              @db.Uuid
  provider    String
  category    IntegrationCategory
  status      IntegrationStatus   @default(disconnected)
  config      Json                @default("{}")
  lastSyncAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([status])
}

model TeamMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  email     String
  name      String?
  role      TeamRole @default(viewer)
  firebaseUid String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

model Invitation {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String           @db.Uuid
  email       String
  role        TeamRole         @default(viewer)
  status      InvitationStatus @default(pending)
  invitedBy   String
  token       String           @unique @default(dbgenerated("gen_random_uuid()"))
  expiresAt   DateTime
  createdAt   DateTime         @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([token])
}

model NotificationPreference {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String           @db.Uuid
  userId    String
  type      NotificationType
  enabled   Boolean          @default(true)
  channel   String           @default("email")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, type])
  @@index([tenantId])
  @@index([userId])
}

model SecuritySetting {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @unique @db.Uuid
  twoFactorEnabled    Boolean  @default(false)
  ssoEnabled          Boolean  @default(false)
  ssoProvider         String?
  ssoConfig           Json     @default("{}")
  auditRetentionDays  Int      @default(730)
  gdprCompliant       Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
