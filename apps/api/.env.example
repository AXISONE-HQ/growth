# growth API Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/growth

# CORS
CORS_ORIGIN=http://localhost:3000

# Firebase Admin (for JWT verification)
FIREBASE_PROJECT_ID=growth-493400

# Admin allowlist for adminProcedure (KAN-702 PR A.1 — pre-launch single-admin pattern).
# Comma-separated emails granted access to admin-gated tRPC mutations (pipelines,
# stages, targets, knowledge filters, etc.). Default-deny: empty/unset → reject.
# Migrate to TeamMember-based per-tenant role authority in Sprint 7 (KAN-714).
ADMIN_EMAILS=

# Port
PORT=8080
